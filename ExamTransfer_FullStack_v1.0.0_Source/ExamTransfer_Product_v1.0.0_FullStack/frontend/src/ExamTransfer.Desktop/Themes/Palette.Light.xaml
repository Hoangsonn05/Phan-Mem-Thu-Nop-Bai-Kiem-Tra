    <Color x:Key="Color.Info">#0369A1</Color>
    <Color x:Key="Color.InfoSoft">#E0F2FE</Color>
    <Color x:Key="Color.OnPrimary">#FFFFFFFF</Color>
    <Color x:Key="Color.OnPrimaryMuted">#DBEAFE</Color>
    <Color x:Key="Color.OnDanger">#FFFFFFFF</Color>
    <Color x:Key="Color.HeroText">#FFFFFFFF</Color>
    <Color x:Key="Color.HeroMuted">#E5F0FF</Color>
    <Color x:Key="Color.HeroAvatar">#FFFFFFFF</Color>
    <Color x:Key="Color.HeroAvatarForeground">#1D4ED8</Color>
