<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Color.AppBackground">#F1F5FB</Color>
    <Color x:Key="Color.Surface">#FFFFFFFF</Color>
    <Color x:Key="Color.SurfaceSubtle">#F8FAFC</Color>
    <Color x:Key="Color.SurfaceRaised">#FFFFFFFF</Color>
    <Color x:Key="Color.Border">#E2E8F0</Color>
