<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- ═══════════════════════════════════════════════════════
         ExamTransfer Light Palette v2 – Slate Studio / Teal
         Primary: Teal-600 (#0D9488)  Sidebar: Slate-800 (#1C2333)
    ═══════════════════════════════════════════════════════ -->

    <!-- SURFACE -->
    <Color x:Key="Color.AppBackground">#F0F2F5</Color>
    <Color x:Key="Color.Surface">#FFFFFFFF</Color>
    <Color x:Key="Color.SurfaceSubtle">#F7F8FA</Color>
    <Color x:Key="Color.SurfaceRaised">#FFFFFFFF</Color>

    <!-- BORDER -->
    <Color x:Key="Color.Border">#E4E7EC</Color>
    <Color x:Key="Color.BorderStrong">#CDD3DE</Color>

    <!-- TEXT -->
    <Color x:Key="Color.TextPrimary">#111827</Color>
    <Color x:Key="Color.TextSecondary">#4B5563</Color>
    <Color x:Key="Color.TextMuted">#6B7280</Color>

    <!-- PRIMARY – Teal -->
    <Color x:Key="Color.Primary">#0D9488</Color>
    <Color x:Key="Color.PrimaryHover">#0F766E</Color>
    <Color x:Key="Color.PrimaryPressed">#115E59</Color>
    <Color x:Key="Color.PrimarySoft">#CCFBF1</Color>

    <!-- ACCENT – Cyan (realtime / transfer) -->
    <Color x:Key="Color.Accent">#0891B2</Color>
    <Color x:Key="Color.AccentSoft">#CFFAFE</Color>

    <!-- SEMANTIC -->
    <Color x:Key="Color.Success">#059669</Color>
    <Color x:Key="Color.SuccessSoft">#D1FAE5</Color>
    <Color x:Key="Color.SuccessOnSoft">#065F46</Color>
    <Color x:Key="Color.Warning">#D97706</Color>
    <Color x:Key="Color.WarningSoft">#FEF3C7</Color>
    <Color x:Key="Color.Danger">#DC2626</Color>
    <Color x:Key="Color.DangerSoft">#FEE2E2</Color>
    <Color x:Key="Color.DangerHover">#B91C1C</Color>
    <Color x:Key="Color.Info">#2563EB</Color>
    <Color x:Key="Color.InfoSoft">#DBEAFE</Color>

    <!-- ON-COLOR -->
    <Color x:Key="Color.OnPrimary">#FFFFFFFF</Color>
    <Color x:Key="Color.OnPrimaryMuted">#CCFBF1</Color>
    <Color x:Key="Color.OnDanger">#FFFFFFFF</Color>

    <!-- HERO -->
    <Color x:Key="Color.HeroText">#FFFFFFFF</Color>
    <Color x:Key="Color.HeroMuted">#CCFBF1</Color>
    <Color x:Key="Color.HeroAvatar">#FFFFFFFF</Color>
    <Color x:Key="Color.HeroAvatarForeground">#0F766E</Color>
    <Color x:Key="Color.OverlaySoft">#28FFFFFF</Color>

    <!-- INPUT -->
    <Color x:Key="Color.InputSelection">#99F6E4</Color>

    <!-- SIDEBAR – Slate dark (không phải blue) -->
    <Color x:Key="Color.Sidebar">#1C2333</Color>
    <Color x:Key="Color.SidebarHover">#252E42</Color>
    <Color x:Key="Color.SidebarActive">#1A2130</Color>
    <Color x:Key="Color.SidebarText">#F1F5F9</Color>
    <Color x:Key="Color.SidebarMuted">#94A3B8</Color>
    <Color x:Key="Color.SidebarBadge">#3DFFFFFF</Color>
    <Color x:Key="Color.SidebarActiveIndicator">#2DD4BF</Color>

    <!-- DATAGRID -->
    <Color x:Key="Color.DataGridRowHover">#F0FDF9</Color>
    <Color x:Key="Color.DataGridRowSelected">#CCFBF1</Color>

    <!-- FOCUS / SCROLL -->
    <Color x:Key="Color.FocusRing">#0D9488</Color>
    <Color x:Key="Color.ScrollThumb">#CDD3DE</Color>
    <Color x:Key="Color.ScrollThumbHover">#94A3B8</Color>

    <!-- ═══════════ BRUSHES ═══════════ -->
    <SolidColorBrush x:Key="AppBackgroundBrush"         Color="{StaticResource Color.AppBackground}"/>
    <SolidColorBrush x:Key="SurfaceBrush"               Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="SurfaceSubtleBrush"         Color="{StaticResource Color.SurfaceSubtle}"/>
    <SolidColorBrush x:Key="SurfaceRaisedBrush"         Color="{StaticResource Color.SurfaceRaised}"/>
    <SolidColorBrush x:Key="BorderBrush"                Color="{StaticResource Color.Border}"/>
    <SolidColorBrush x:Key="BorderStrongBrush"          Color="{StaticResource Color.BorderStrong}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"           Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"         Color="{StaticResource Color.TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"             Color="{StaticResource Color.TextMuted}"/>
    <SolidColorBrush x:Key="PrimaryBrush"               Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"          Color="{StaticResource Color.PrimaryHover}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush"        Color="{StaticResource Color.PrimaryPressed}"/>
    <SolidColorBrush x:Key="PrimarySoftBrush"           Color="{StaticResource Color.PrimarySoft}"/>
    <SolidColorBrush x:Key="AccentBrush"                Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="AccentSoftBrush"            Color="{StaticResource Color.AccentSoft}"/>
    <SolidColorBrush x:Key="SuccessBrush"               Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="SuccessSoftBrush"           Color="{StaticResource Color.SuccessSoft}"/>
    <SolidColorBrush x:Key="WarningBrush"               Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush x:Key="WarningSoftBrush"           Color="{StaticResource Color.WarningSoft}"/>
    <SolidColorBrush x:Key="DangerBrush"                Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="DangerSoftBrush"            Color="{StaticResource Color.DangerSoft}"/>
    <SolidColorBrush x:Key="DangerHoverBrush"           Color="{StaticResource Color.DangerHover}"/>
    <SolidColorBrush x:Key="InfoBrush"                  Color="{StaticResource Color.Info}"/>
    <SolidColorBrush x:Key="InfoSoftBrush"              Color="{StaticResource Color.InfoSoft}"/>
    <SolidColorBrush x:Key="OnPrimaryBrush"             Color="{StaticResource Color.OnPrimary}"/>
    <SolidColorBrush x:Key="OnPrimaryMutedBrush"        Color="{StaticResource Color.OnPrimaryMuted}"/>
    <SolidColorBrush x:Key="OnDangerBrush"              Color="{StaticResource Color.OnDanger}"/>
    <SolidColorBrush x:Key="HeroTextBrush"              Color="{StaticResource Color.HeroText}"/>
    <SolidColorBrush x:Key="HeroMutedBrush"             Color="{StaticResource Color.HeroMuted}"/>
    <SolidColorBrush x:Key="HeroAvatarBrush"            Color="{StaticResource Color.HeroAvatar}"/>
    <SolidColorBrush x:Key="HeroAvatarForegroundBrush"  Color="{StaticResource Color.HeroAvatarForeground}"/>
    <SolidColorBrush x:Key="OverlaySoftBrush"           Color="{StaticResource Color.OverlaySoft}"/>
    <SolidColorBrush x:Key="SuccessOnSoftBrush"         Color="{StaticResource Color.SuccessOnSoft}"/>
    <SolidColorBrush x:Key="InputSelectionBrush"        Color="{StaticResource Color.InputSelection}"/>
    <SolidColorBrush x:Key="SidebarBrush"               Color="{StaticResource Color.Sidebar}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush"          Color="{StaticResource Color.SidebarHover}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush"         Color="{StaticResource Color.SidebarActive}"/>
    <SolidColorBrush x:Key="SidebarTextBrush"           Color="{StaticResource Color.SidebarText}"/>
    <SolidColorBrush x:Key="SidebarMutedBrush"          Color="{StaticResource Color.SidebarMuted}"/>
    <SolidColorBrush x:Key="SidebarBadgeBrush"          Color="{StaticResource Color.SidebarBadge}"/>
    <SolidColorBrush x:Key="SidebarActiveIndicatorBrush" Color="{StaticResource Color.SidebarActiveIndicator}"/>
    <SolidColorBrush x:Key="DataGridRowHoverBrush"      Color="{StaticResource Color.DataGridRowHover}"/>
    <SolidColorBrush x:Key="DataGridRowSelectedBrush"   Color="{StaticResource Color.DataGridRowSelected}"/>
    <SolidColorBrush x:Key="FocusRingBrush"             Color="{StaticResource Color.FocusRing}"/>
    <SolidColorBrush x:Key="ScrollThumbBrush"           Color="{StaticResource Color.ScrollThumb}"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush"      Color="{StaticResource Color.ScrollThumbHover}"/>
</ResourceDictionary>
