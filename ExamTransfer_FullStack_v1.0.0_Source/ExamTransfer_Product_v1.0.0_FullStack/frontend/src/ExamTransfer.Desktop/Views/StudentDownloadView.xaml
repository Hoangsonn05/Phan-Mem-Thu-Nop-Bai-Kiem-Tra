<UserControl x:Class="ExamTransfer.Desktop.Views.StudentDownloadView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="Nhận đề" Style="{StaticResource PageTitleText}"/><TextBlock Text="Tải manifest và file đề, tiếp tục tải khi gián đoạn và chỉ mở sau khi xác minh." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Tải manifest" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/><Button Content="Tải tất cả" Command="{Binding DownloadAllCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel></Grid><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="0.7*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="File đề" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"><DataGrid.Columns><DataGridTextColumn Header="TÊN FILE" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="DUNG LƯỢNG" Binding="{Binding SizeBytes}" Width="110"/><DataGridTextColumn Header="MIME" Binding="{Binding MimeType}" Width="150"/><DataGridTextColumn Header="SHA-256" Binding="{Binding Sha256}" Width="180"/></DataGrid.Columns></DataGrid><ProgressBar Grid.Row="2" Value="{Binding Progress}" Height="8" Margin="18,12,18,16"/></Grid></Border><Border Grid.Column="2" Style="{StaticResource Card}"><StackPanel><TextBlock Text="Nơi lưu đề" Style="{StaticResource SectionTitleText}"/><TextBox Text="{Binding Destination}" Margin="0,14,0,0"/><Button Content="Chọn thư mục" Command="{Binding BrowseCommand}" Style="{StaticResource SecondaryButton}" Margin="0,8,0,0"/><Button Content="Tải file đã chọn" Command="{Binding DownloadCommand}" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0"/><Border Style="{StaticResource SubtleCard}" Margin="0,16,0,0"><TextBlock Text="Ứng dụng tải theo stream và không giữ toàn bộ file trong RAM. File chỉ được dùng sau khi máy chủ trả về dữ liệu đầy đủ." Style="{StaticResource BodyText}"/></Border></StackPanel></Border></Grid><Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>