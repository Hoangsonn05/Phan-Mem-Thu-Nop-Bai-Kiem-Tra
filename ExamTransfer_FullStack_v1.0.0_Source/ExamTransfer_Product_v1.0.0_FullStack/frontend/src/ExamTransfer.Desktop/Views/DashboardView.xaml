<UserControl x:Class="ExamTransfer.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Tổng quan hệ thống" Style="{StaticResource DisplayTitleText}" />
                    <TextBlock Text="Theo dõi lớp học, kỳ thi và các cảnh báo cần xử lý trong một nơi." Style="{StaticResource BodyText}" Margin="0,5,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" FontSize="16" />
                        <TextBlock Text="Làm mới" Margin="8,0,0,0" />
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Metrics}" Margin="0,24,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,14,0" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                                    <Border Grid.Column="1" Width="38" Height="38" CornerRadius="11"
                                            Background="{Binding Tone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                                        <TextBlock Text="{Binding Glyph}" Style="{StaticResource IconText}" FontSize="18"
                                                   Foreground="{Binding Tone, Converter={StaticResource ToneBrushConverter}}" />
                                    </Border>
                                </Grid>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionText}" Margin="8,10,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Row="2" Text="{Binding Trend}" Margin="0,9,0,0" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{Binding Tone, Converter={StaticResource ToneBrushConverter}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="2" Margin="0,24,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.55*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Padding="22" CornerRadius="14,14,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1D4ED8" Offset="0" />
                                    <GradientStop Color="#0891B2" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="PHÒNG THI ĐANG HOẠT ĐỘNG" Foreground="#DBEAFE" FontSize="10" FontWeight="Bold" />
                                    <TextBlock Text="{Binding ActiveSession.Title}" Foreground="White" FontSize="21" FontWeight="SemiBold" Margin="0,7,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Border Padding="8,3" CornerRadius="999" Background="#28FFFFFF">
                                            <TextBlock Text="{Binding ActiveSession.RoomCode}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Text="{Binding ActiveSession.Status}" Foreground="#E0F2FE" FontSize="12" Margin="10,3,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="THỜI GIAN CÒN LẠI" Foreground="#DBEAFE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding ActiveSession.TimeLeft}" Foreground="White" FontSize="30" FontWeight="SemiBold" FontFamily="Consolas" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="22,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Thiết bị đang kết nối" Style="{StaticResource CardTitleText}" />
                                    <TextBlock Text="{Binding ActiveSession.Connected}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                </Grid>
                                <ProgressBar Value="{Binding ActiveSession.ConnectedPercent, Mode=OneWay}" Margin="0,10,0,0" Foreground="{DynamicResource AccentBrush}" />
                                <TextBlock Text="{Binding ActiveSession.Total, StringFormat='Tổng {0} thiết bị'}" Style="{StaticResource CaptionText}" Margin="0,7,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Grid>
                                    <TextBlock Text="Bài đã nộp" Style="{StaticResource CardTitleText}" />
                                    <TextBlock Text="{Binding ActiveSession.Submitted}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                </Grid>
                                <ProgressBar Value="{Binding ActiveSession.SubmittedPercent, Mode=OneWay}" Margin="0,10,0,0" Foreground="{DynamicResource SuccessBrush}" />
                                <TextBlock Text="Được máy chủ xác nhận" Style="{StaticResource CaptionText}" Margin="0,7,0,0" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,15">
                            <Grid>
                                <TextBlock Text="Theo dõi realtime, upload và cảnh báo thiết bị" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                                <Button Content="Mở giám sát" HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}" MinHeight="38" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Margin="20,18,20,12">
                            <TextBlock Text="Cảnh báo cần chú ý" Style="{StaticResource SectionTitleText}" />
                            <Border HorizontalAlignment="Right" Style="{StaticResource StatusPill}" Background="{DynamicResource WarningSoftBrush}">
                                <TextBlock Text="{Binding Alerts.Count, StringFormat={}{0} mục}" Foreground="{DynamicResource WarningBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Alerts}" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SubtleCard}" Margin="0,0,0,8" Padding="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="30" Height="30" CornerRadius="9"
                                                    Background="{Binding Tone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                                                <TextBlock Text="{Binding Glyph}" Style="{StaticResource IconText}" FontSize="14"
                                                           Foreground="{Binding Tone, Converter={StaticResource ToneBrushConverter}}" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Title}" Style="{StaticResource CardTitleText}" FontSize="13" />
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,24,0,4" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Margin="22,18,22,12">
                        <TextBlock Text="Hoạt động gần đây" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="{Binding Status}" Style="{StaticResource CaptionText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Activities}" Margin="18,0,18,14">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="68" />
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Time}" Style="{StaticResource CaptionText}" VerticalAlignment="Center" FontFamily="Consolas" />
                                    <Border Grid.Column="1" Width="30" Height="30" CornerRadius="15"
                                            Background="{Binding Tone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                                        <TextBlock Text="{Binding Glyph}" Style="{StaticResource IconText}" FontSize="14"
                                                   Foreground="{Binding Tone, Converter={StaticResource ToneBrushConverter}}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource CardTitleText}" FontSize="13" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
