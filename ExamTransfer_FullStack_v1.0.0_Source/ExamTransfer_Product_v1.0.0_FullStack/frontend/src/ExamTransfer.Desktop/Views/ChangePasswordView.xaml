<UserControl x:Class="ExamTransfer.Desktop.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32">
            <Border Style="{StaticResource Card}"
                    MaxWidth="720"
                    HorizontalAlignment="Center"
                    Padding="32">
                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="18"
                            Background="{DynamicResource WarningSoftBrush}"
                            HorizontalAlignment="Left">
                        <TextBlock Text="&#xE72E;"
                                   Style="{StaticResource IconText}"
                                   FontSize="28"
                                   Foreground="{DynamicResource WarningBrush}" />
                    </Border>

                    <TextBlock Text="Đổi mật khẩu bắt buộc"
                               Style="{StaticResource DisplayTitleText}"
                               Margin="0,18,0,6" />
                    <TextBlock Text="Để bảo vệ tài khoản, bạn phải thay mật khẩu chung bằng mật khẩu cá nhân trước khi vào phòng thi."
                               Style="{StaticResource BodyText}"
                               TextWrapping="Wrap" />

                    <Border Style="{StaticResource SubtleCard}" Margin="0,20,0,0" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StudentCode, StringFormat=Mã sinh viên: {0}}"
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,3,0,0"
                                       FontFamily="Consolas" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Mật khẩu hiện tại" FontWeight="SemiBold" FontSize="12" Margin="0,22,0,0" />
                    <PasswordBox x:Name="CurrentPasswordInput"
                                 PasswordChanged="OnCurrentPasswordChanged"
                                 Margin="0,6,0,14" />

                    <TextBlock Text="Mật khẩu mới" FontWeight="SemiBold" FontSize="12" />
                    <PasswordBox x:Name="NewPasswordInput"
                                 PasswordChanged="OnNewPasswordChanged"
                                 Margin="0,6,0,14" />

                    <TextBlock Text="Nhập lại mật khẩu mới" FontWeight="SemiBold" FontSize="12" />
                    <PasswordBox x:Name="ConfirmPasswordInput"
                                 PasswordChanged="OnConfirmPasswordChanged"
                                 Margin="0,6,0,0" />

                    <Border Style="{StaticResource SubtleCard}" Margin="0,18,0,0" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Mật khẩu mới phải có:" FontWeight="SemiBold" />
                            <TextBlock Text="• Từ 8 đến 72 ký tự" Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                            <TextBlock Text="• Chữ hoa, chữ thường, chữ số và ký tự đặc biệt" Style="{StaticResource CaptionText}" />
                            <TextBlock Text="• Không chứa từ uneti, mã sinh viên hoặc tên tài khoản" Style="{StaticResource CaptionText}" />
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding ChangePasswordCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,20,0,0"
                            MinHeight="44"
                            Content="Đổi mật khẩu và tiếp tục" />

                    <Border Style="{StaticResource StatusPill}"
                            HorizontalAlignment="Left"
                            Margin="0,18,0,0"
                            Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                        <TextBlock Text="{Binding Status}"
                                   Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
