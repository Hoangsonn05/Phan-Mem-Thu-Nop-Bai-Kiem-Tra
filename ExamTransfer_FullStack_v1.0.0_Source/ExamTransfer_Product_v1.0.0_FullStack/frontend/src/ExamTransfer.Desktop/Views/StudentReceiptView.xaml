<UserControl x:Class="ExamTransfer.Desktop.Views.StudentReceiptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Biên nhận bài nộp"
                       Style="{StaticResource PageTitleText}" />
            <TextBlock Text="Mã xác nhận, thời gian máy chủ nhận bài, chữ ký và hash file."
                       Style="{StaticResource BodyText}"
                       Margin="0,5,0,0" />
        </StackPanel>

        <!-- Receipt card -->
        <Border Grid.Row="2"
                Style="{StaticResource Card}"
                MaxWidth="800"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <StackPanel>
                <!-- Success icon -->
                <Border Width="68"
                        Height="68"
                        CornerRadius="20"
                        Background="{DynamicResource SuccessSoftBrush}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="&#xE73E;"
                               Style="{StaticResource IconText}"
                               FontSize="30"
                               Foreground="{DynamicResource SuccessBrush}" />
                </Border>

                <TextBlock Text="Máy chủ đã xác nhận bài nộp"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,18,0,0" />

                <TextBlock Text="{Binding Receipt.ReceiptCode, TargetNullValue=Chưa có biên nhận}"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           HorizontalAlignment="Center"
                           FontFamily="Consolas"
                           Margin="0,10,0,0" />

                <!-- Summary -->
                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Thời gian máy chủ"
                                   Style="{StaticResource CaptionText}" />
                        <TextBlock Text="{Binding Receipt.ServerReceivedAtUtc}"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Trạng thái"
                                   Style="{StaticResource CaptionText}" />
                        <TextBlock Text="Đã xác nhận"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Chữ ký"
                                   Style="{StaticResource CaptionText}" />
                        <TextBlock Text="Hợp lệ"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>

                <!-- File list -->
                <DataGrid ItemsSource="{Binding Receipt.Files}"
                          Height="170"
                          Margin="0,20,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FILE" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="DUNG LƯỢNG" Binding="{Binding SizeBytes}" Width="110" />
                        <DataGridTextColumn Header="SHA-256" Binding="{Binding Sha256}" Width="220" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0">
                    <Button Content="Tải lại"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButton}" />
                    <Button Content="Sao chép mã"
                            Command="{Binding CopyCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0" />
                    <Button Content="Lưu JSON"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Style="{StaticResource StatusPill}"
                HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}"
                       Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>