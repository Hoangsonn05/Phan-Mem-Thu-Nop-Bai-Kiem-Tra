<UserControl x:Class="ExamTransfer.Desktop.Views.StudentReceiptView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="24"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Biên nhận bài nộp" Style="{StaticResource PageTitleText}"/><TextBlock Text="Mã xác nhận, thời gian máy chủ nhận bài, chữ ký và hash file." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><Border Grid.Row="2" Style="{StaticResource Card}" MaxWidth="760" HorizontalAlignment="Center" VerticalAlignment="Top"><StackPanel><Border Width="64" Height="64" CornerRadius="20" Background="{DynamicResource SuccessSoftBrush}" HorizontalAlignment="Center"><TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" FontSize="28" Foreground="{DynamicResource SuccessBrush}"/></Border><TextBlock Text="Máy chủ đã xác nhận bài nộp" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,0"/><TextBlock Text="{Binding Receipt.ReceiptCode, TargetNullValue=Chưa có biên nhận}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,10,0,0"/><Grid Margin="0,22,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Thời gian máy chủ" Style="{StaticResource CaptionText}"/><TextBlock Text="{Binding Receipt.ServerReceivedAtUtc}" FontWeight="SemiBold"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Trạng thái" Style="{StaticResource CaptionText}"/><TextBlock Text="Đã xác nhận" FontWeight="SemiBold"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Chữ ký" Style="{StaticResource CaptionText}"/><TextBlock Text="Hợp lệ" FontWeight="SemiBold"/></StackPanel></Grid><DataGrid ItemsSource="{Binding Receipt.Files}" Height="170" Margin="0,18,0,0"><DataGrid.Columns><DataGridTextColumn Header="FILE" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="DUNG LƯỢNG" Binding="{Binding SizeBytes}" Width="110"/><DataGridTextColumn Header="SHA-256" Binding="{Binding Sha256}" Width="220"/></DataGrid.Columns></DataGrid><StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0"><Button Content="Tải lại" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/><Button Content="Sao chép mã" Command="{Binding CopyCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/><Button Content="Lưu JSON" Command="{Binding SaveCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/></StackPanel></StackPanel></Border><Border Grid.Row="3" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>