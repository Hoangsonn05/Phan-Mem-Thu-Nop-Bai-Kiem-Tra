<UserControl x:Class="ExamTransfer.Desktop.Views.StudentExamView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
<Grid><StackPanel><TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleText}"/><TextBlock Text="{Binding Subject}" Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Border Style="{StaticResource StatusPill}" Background="{DynamicResource PrimarySoftBrush}"><StackPanel Orientation="Horizontal"><TextBlock Text="Phòng " Foreground="{DynamicResource PrimaryBrush}"/><TextBlock Text="{Binding RoomCode}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/></StackPanel></Border><Button Content="Đồng bộ" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/><Button Content="Kiểm tra kết nối" Command="{Binding HeartbeatCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/></StackPanel></Grid>
<Border Grid.Row="2" CornerRadius="16" Background="{DynamicResource PrimaryBrush}" Padding="28"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Thời gian còn lại" Foreground="#DDEBFF"/><TextBlock Text="{Binding TimeLeft}" Foreground="White" FontSize="42" FontWeight="Bold" FontFamily="Consolas" Margin="0,4,0,0"/><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Connection}" Foreground="#DDEBFF"/><TextBlock Text=" · Thí sinh: " Foreground="#DDEBFF"/><TextBlock Text="{Binding CandidateCount}" Foreground="#DDEBFF" FontWeight="SemiBold"/></StackPanel></StackPanel><ProgressBar Grid.Column="1" Value="{Binding TimeProgress}" Width="300" Height="12" VerticalAlignment="Center"/></Grid></Border>
<Grid Grid.Row="4"><Grid.ColumnDefinitions><ColumnDefinition Width="0.85*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="1.15*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Tiến trình kỳ thi" Style="{StaticResource SectionTitleText}"/><ItemsControl ItemsSource="{Binding Steps}" Margin="0,14,0,0"><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource SubtleCard}" Margin="0,0,0,8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="40"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Width="30" Height="30" CornerRadius="15" Background="{DynamicResource PrimarySoftBrush}"><TextBlock Text="{Binding Number}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/></Border><TextBlock Grid.Column="1" Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding Status}" Style="{StaticResource CaptionText}" VerticalAlignment="Center"/></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
<Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="220"/></Grid.RowDefinitions><Grid Margin="18,16,18,10"><StackPanel><TextBlock Text="Thư mục làm bài" Style="{StaticResource SectionTitleText}"/><TextBlock Text="{Binding WorkspaceFolder}" Style="{StaticResource CaptionText}" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Chọn thư mục" Command="{Binding BrowseWorkspaceCommand}" Style="{StaticResource SecondaryButton}"/><Button Content="Mở" Command="{Binding OpenWorkspaceCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/><Button Content="Quét lại" Command="{Binding RefreshWorkspaceCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel></Grid><TextBlock Grid.Row="1" Text="Chỉ các file trong thư mục này được dùng làm nguồn chọn khi nộp bài." Style="{StaticResource BodyText}" Margin="18,0,18,10"/><DataGrid Grid.Row="2" ItemsSource="{Binding WorkspaceFiles}"><DataGrid.Columns><DataGridTextColumn Header="TÊN FILE" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="DUNG LƯỢNG" Binding="{Binding Size}" Width="110"/><DataGridTextColumn Header="CHỈNH SỬA" Binding="{Binding Modified}" Width="145"/><DataGridTextColumn Header="KIỂM TRA" Binding="{Binding Status}" Width="110"/></DataGrid.Columns></DataGrid></Grid></Border></Grid>
<Border Grid.Row="6" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border>
</Grid></ScrollViewer></UserControl>