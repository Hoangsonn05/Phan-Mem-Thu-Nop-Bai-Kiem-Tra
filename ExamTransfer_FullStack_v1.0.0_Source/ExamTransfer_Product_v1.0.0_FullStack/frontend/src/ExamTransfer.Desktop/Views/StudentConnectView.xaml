<UserControl x:Class="ExamTransfer.Desktop.Views.StudentConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32" MaxWidth="1180" HorizontalAlignment="Center">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" MaxWidth="720">
                <Border Width="58" Height="58" CornerRadius="18" Background="{DynamicResource PrimarySoftBrush}" HorizontalAlignment="Center"><TextBlock Text="&#xE968;" Style="{StaticResource IconText}" FontSize="25" Foreground="{DynamicResource PrimaryBrush}"/></Border>
                <TextBlock Text="Tham gia phòng thi" Style="{StaticResource DisplayTitleText}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                <TextBlock Text="Ứng dụng tự tìm các phòng đang mở trong mạng nội bộ. Chọn phòng, kiểm tra thông tin rồi gửi yêu cầu tham gia." Style="{StaticResource BodyText}" TextAlignment="Center" Margin="0,7,0,0"/>
            </StackPanel>
            <Grid Grid.Row="1" Margin="0,28,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.35*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid Margin="20,18,20,12"><StackPanel><TextBlock Text="Phòng đang mở" Style="{StaticResource SectionTitleText}"/><TextBlock Text="{Binding Status}" Style="{StaticResource CaptionText}" Margin="0,3,0,0" TextWrapping="Wrap"/></StackPanel><Button Command="{Binding ScanCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" Content="Quét lại"/></Grid>
                        <ListBox Grid.Row="1" ItemsSource="{Binding Rooms}" SelectedItem="{Binding SelectedRoom}" Background="Transparent" BorderThickness="0" Margin="12,0,12,12" MinHeight="270">
                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0,0,0,8"/></Style></ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate><DataTemplate><Border Padding="15" CornerRadius="11" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding ClassDisplay}" FontWeight="SemiBold"/><TextBlock Text="{Binding ExamTitle}" Style="{StaticResource BodyText}" Margin="0,4,0,0"/><TextBlock Text="{Binding TeacherName, StringFormat=Giáo viên: {0}}" Style="{StaticResource CaptionText}" Margin="0,3,0,0"/><TextBlock Text="{Binding ApprovalText}" Style="{StaticResource CaptionText}" Margin="0,3,0,0"/></StackPanel><StackPanel Grid.Column="1" HorizontalAlignment="Right"><TextBlock Text="{Binding RoomCode}" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Right"/><TextBlock Text="{Binding CapacityText}" Style="{StaticResource CaptionText}" HorizontalAlignment="Right" Margin="0,6,0,0"/><TextBlock Text="{Binding StartText}" Style="{StaticResource CaptionText}" HorizontalAlignment="Right" Margin="0,3,0,0"/></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Xác nhận tham gia" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="Họ tên" FontWeight="SemiBold" FontSize="12" Margin="0,18,0,0"/><TextBox Text="{Binding DisplayName}" IsReadOnly="True" Margin="0,6,0,0"/>
                        <TextBlock Text="Mã sinh viên" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,0"/><TextBox Text="{Binding StudentCode}" IsReadOnly="True" Margin="0,6,0,0"/>
                        <TextBlock Text="Lớp" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,0"/><TextBox Text="{Binding ClassName}" IsReadOnly="True" Margin="0,6,0,0"/>
                        <TextBlock Text="Mã lớp" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,0"/><TextBox Text="{Binding ClassCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" CharacterCasing="Upper"/>
                        <TextBlock Text="Mã phòng" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,0"/><TextBox Text="{Binding RoomCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" CharacterCasing="Upper"/>
                        <TextBlock Text="Có thể nhập mã phòng dự phòng; ứng dụng chỉ tìm mã này trên các máy giáo viên đã khám phá." Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,7,0,0"/>
                        <Button Command="{Binding JoinCommand}" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0" Content="Gửi yêu cầu tham gia"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,20,0,4" Padding="18"><ItemsControl ItemsSource="{Binding Readiness}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><StackPanel Margin="8"><TextBlock Text="{Binding Title}" FontWeight="SemiBold"/><TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Border>
        </Grid>
    </ScrollViewer>
</UserControl>
