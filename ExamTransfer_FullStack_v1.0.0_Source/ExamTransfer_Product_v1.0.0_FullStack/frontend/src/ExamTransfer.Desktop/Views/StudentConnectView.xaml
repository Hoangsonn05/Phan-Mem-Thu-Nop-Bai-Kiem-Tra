<UserControl x:Class="ExamTransfer.Desktop.Views.StudentConnectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32" MaxWidth="1180" HorizontalAlignment="Center">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" MaxWidth="720">
                <Border Width="58" Height="58" CornerRadius="18" Background="{DynamicResource PrimarySoftBrush}" HorizontalAlignment="Center"><TextBlock Text="&#xE968;" Style="{StaticResource IconText}" FontSize="25" Foreground="{DynamicResource PrimaryBrush}"/></Border>
                <TextBlock Text="Kết nối với máy giáo viên" Style="{StaticResource DisplayTitleText}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                <TextBlock Text="Tự động tìm máy chủ trong LAN hoặc nhập địa chỉ thủ công. Không tự tham gia phòng khi chưa xác nhận." Style="{StaticResource BodyText}" TextAlignment="Center" Margin="0,7,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,28,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.3*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid Margin="20,18,20,12"><StackPanel><TextBlock Text="Máy chủ được phát hiện" Style="{StaticResource SectionTitleText}"/><TextBlock Text="{Binding Status}" Style="{StaticResource CaptionText}" Margin="0,3,0,0"/></StackPanel><Button Command="{Binding ScanCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" FontSize="15"/><TextBlock Text="Quét lại" Margin="7,0,0,0"/></StackPanel></Button></Grid>
                        <ListBox Grid.Row="1" ItemsSource="{Binding Servers}" SelectedItem="{Binding SelectedServer}" Background="Transparent" BorderThickness="0" Margin="12,0,12,8">
                            <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0,0,0,8"/><Setter Property="Background" Value="Transparent"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Root" Padding="15" CornerRadius="11" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Root" Property="Background" Value="{DynamicResource PrimarySoftBrush}"/><Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter TargetName="Root" Property="BorderThickness" Value="2"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style></ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate><DataTemplate><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Width="38" Height="38" CornerRadius="11" Background="{Binding Tone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="&#xE7FC;" Style="{StaticResource IconText}" Foreground="{Binding Tone, Converter={StaticResource ToneBrushConverter}}"/></Border><StackPanel Grid.Column="1" Margin="10,0"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Teacher}" Style="{StaticResource CaptionText}"/><StackPanel Orientation="Horizontal" Margin="0,5,0,0"><TextBlock Text="{Binding Address}" Style="{StaticResource CaptionText}" FontFamily="Consolas"/><TextBlock Text=" · " Style="{StaticResource CaptionText}"/><TextBlock Text="{Binding LatencyMs, StringFormat={}{0} ms}" Foreground="{DynamicResource SuccessBrush}" FontSize="11"/></StackPanel></StackPanel><StackPanel Grid.Column="2" HorizontalAlignment="Right"><Border Style="{StaticResource StatusPill}" Background="{Binding Tone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding Tone, Converter={StaticResource ToneBrushConverter}}" FontSize="10" FontWeight="SemiBold"/></Border><TextBlock Text="{Binding CapacityText}" Style="{StaticResource CaptionText}" HorizontalAlignment="Right" Margin="0,6,0,0"/></StackPanel></Grid></DataTemplate></ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,15"><TextBlock Text="Chọn một máy chủ để tự điền IP, cổng và mã phòng" Style="{StaticResource CaptionText}"/></Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Tham gia bằng địa chỉ" Style="{StaticResource SectionTitleText}"/>
                        <TextBlock Text="Dùng khi máy chủ không xuất hiện trong danh sách tự động." Style="{StaticResource CaptionText}" Margin="0,4,0,18"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Họ tên *" FontWeight="SemiBold" FontSize="12"/><TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,6,0,0"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Mã học sinh *" FontWeight="SemiBold" FontSize="12"/><TextBox Text="{Binding StudentCode, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,6,0,0"/></StackPanel></Grid>
                        <TextBlock Text="Lớp" FontWeight="SemiBold" FontSize="12" Margin="0,12,0,0"/>
                        <TextBox Text="{Binding ClassName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12"/>
                        <TextBlock Text="Địa chỉ IP" FontWeight="SemiBold" FontSize="12"/>
                        <TextBox Text="{Binding Ip, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,14"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="14"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Cổng" FontWeight="SemiBold" FontSize="12"/><TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Mã phòng" FontWeight="SemiBold" FontSize="12"/><TextBox Text="{Binding RoomCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" CharacterCasing="Upper"/></StackPanel></Grid>
                        <Button Command="{Binding JoinCommand}" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0" Content="Gửi yêu cầu tham gia"/>
                        <Border Style="{StaticResource SubtleCard}" Margin="0,16,0,0" Padding="13"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE72E;" Style="{StaticResource IconText}" Foreground="{DynamicResource InfoBrush}"/><TextBlock Text="Token phiên sẽ được gắn với thiết bị sau khi giáo viên duyệt." Style="{StaticResource CaptionText}" Margin="10,0,0,0"/></StackPanel></Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,20,0,4" Padding="0">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="20"><TextBlock Text="Kiểm tra sẵn sàng" Style="{StaticResource SectionTitleText}"/><TextBlock Text="Thiết bị đáp ứng điều kiện cơ bản trước khi tham gia." Style="{StaticResource CaptionText}" Margin="0,5,0,0"/></StackPanel><ItemsControl Grid.Column="1" ItemsSource="{Binding Readiness}" Margin="0,14,16,14"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource SubtleCard}" Margin="0,0,8,0" Padding="12"><StackPanel><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" FontSize="14" Foreground="{DynamicResource SuccessBrush}"/><TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Margin="7,0,0,0"/></StackPanel><TextBlock Text="{Binding Description}" Style="{StaticResource CaptionText}" Margin="0,5,0,0"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
