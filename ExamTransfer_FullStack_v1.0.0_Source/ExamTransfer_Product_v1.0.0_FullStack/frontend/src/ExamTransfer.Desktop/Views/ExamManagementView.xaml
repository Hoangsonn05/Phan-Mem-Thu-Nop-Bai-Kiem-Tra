<UserControl x:Class="ExamTransfer.Desktop.Views.ExamManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Bài kiểm tra và file đề"
                           Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Soạn bài kiểm tra, thiết lập quy định file, phát hành và quản lý phiên bản đề."
                           Style="{StaticResource BodyText}"
                           Margin="0,5,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Làm mới"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Content="Lưu thay đổi"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" />
                <Button Content="Tải file đề"
                        Command="{Binding UploadCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" />
                <Button Content="Tạo bài kiểm tra"
                        Command="{Binding CreateCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Exam list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Danh sách bài kiểm tra"
                               Style="{StaticResource SectionTitleText}"
                               Margin="18,16,18,10" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Exams}"
                              SelectedItem="{Binding SelectedExam}"
                              SelectionChanged="OnExamSelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TIÊU ĐỀ" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="MÔN" Binding="{Binding Subject}" Width="110" />
                            <DataGridTextColumn Header="PHÚT" Binding="{Binding DurationMinutes}" Width="65" />
                            <DataGridTextColumn Header="FILE" Binding="{Binding FileCount}" Width="55" />
                            <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Margin="18,12,18,16">
                        <TextBlock Text="{Binding PublishHint}"
                                   Style="{StaticResource CaptionText}"
                                   Margin="0,0,0,10"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Phát hành"
                                    Command="{Binding PublishCommand}"
                                    Style="{StaticResource PrimaryButton}" />
                            <Button Content="Nhân bản"
                                    Command="{Binding CloneCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" />
                            <Button Content="Lưu trữ"
                                    Command="{Binding ArchiveCommand}"
                                    Style="{StaticResource DangerButton}"
                                    Margin="8,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Detail panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Exam info -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Thông tin và quy định"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="Lớp học"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,14,0,6" />
                            <ComboBox ItemsSource="{Binding Classes}"
                                      SelectedItem="{Binding SelectedClass}"
                                      DisplayMemberPath="Name" />
                            <TextBlock Text="Tiêu đề *"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,12,0,6" />
                            <TextBox Text="{Binding Title}" />
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Môn học *" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Subject}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Thời lượng" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Duration}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Mô tả / hướng dẫn"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,12,0,6" />
                            <TextBox Text="{Binding Description}"
                                     Height="70"
                                     AcceptsReturn="True" />
                            <TextBlock Text="Phần mở rộng cho phép"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,12,0,6" />
                            <TextBox Text="{Binding AllowedExtensions}" />
                        </StackPanel>
                    </Border>

                    <!-- File list -->
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="180" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="File đề và phiên bản"
                                       Style="{StaticResource SectionTitleText}"
                                       Margin="18,16,18,10" />
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Files}"
                                      SelectedItem="{Binding SelectedFile}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="TÊN FILE" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="DUNG LƯỢNG" Binding="{Binding SizeBytes}" Width="100" />
                                    <DataGridTextColumn Header="SHA-256" Binding="{Binding Sha256}" Width="160" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="18,10,18,14">
                                <Button Content="Tải xuống"
                                        Command="{Binding DownloadFileCommand}"
                                        Style="{StaticResource SecondaryButton}" />
                                <Button Content="Xóa file"
                                        Command="{Binding DeleteFileCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Margin="8,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Style="{StaticResource StatusPill}"
                HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}"
                       Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>
