<UserControl x:Class="ExamTransfer.Desktop.Views.ControlCenterView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="Kiểm soát phòng thi" Style="{StaticResource PageTitleText}"/><TextBlock Text="Cấu hình policy, theo dõi khả năng thiết bị và xử lý tín hiệu vi phạm." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><ComboBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}" DisplayMemberPath="RoomCode" Width="160"/><Button Content="Tải trạng thái" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/></StackPanel></Grid><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="0.85*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions><StackPanel><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Policy hiện tại" Style="{StaticResource SectionTitleText}"/><CheckBox Content="Yêu cầu toàn màn hình" IsChecked="{Binding Fullscreen}" Margin="0,14,0,0"/><CheckBox Content="Cho phép thoát khẩn cấp bằng mã giáo viên" IsChecked="{Binding EmergencyExit}" Margin="0,8,0,0"/><TextBlock Text="Quy tắc rời ứng dụng" Style="{StaticResource CaptionText}" Margin="0,12,0,5"/><TextBox Text="{Binding FocusRule}"/><TextBlock Text="Clipboard" Style="{StaticResource CaptionText}" Margin="0,10,0,5"/><TextBox Text="{Binding ClipboardRule}"/><TextBlock Text="Tiến trình bị chặn" Style="{StaticResource CaptionText}" Margin="0,10,0,5"/><TextBox Text="{Binding BlockedProcesses}"/><TextBlock Text="Mạng" Style="{StaticResource CaptionText}" Margin="0,10,0,5"/><TextBox Text="{Binding NetworkRule}"/><Button Content="Lưu policy" Command="{Binding SaveCommand}" Style="{StaticResource SecondaryButton}" Margin="0,14,0,0"/><Button Content="Áp dụng cho phiên" Command="{Binding ApplyCommand}" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0"/></StackPanel></Border></StackPanel><Grid Grid.Column="2"><Grid.RowDefinitions><RowDefinition Height="1*"/><RowDefinition Height="14"/><RowDefinition Height="1*"/></Grid.RowDefinitions><Border Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="Trạng thái thiết bị" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Devices}"><DataGrid.Columns><DataGridTextColumn Header="THIẾT BỊ" Binding="{Binding ParticipantId}" Width="*"/><DataGridTextColumn Header="POLICY" Binding="{Binding PolicyVersion}" Width="70"/><DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="110"/><DataGridTextColumn Header="LỖI" Binding="{Binding Error}" Width="*"/></DataGrid.Columns></DataGrid></Grid></Border><Border Grid.Row="2" Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Vi phạm và xử lý" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Violations}" SelectedItem="{Binding SelectedViolation}"><DataGrid.Columns><DataGridTextColumn Header="THỜI GIAN" Binding="{Binding OccurredAtUtc}" Width="150"/><DataGridTextColumn Header="LOẠI" Binding="{Binding Type}" Width="*"/><DataGridTextColumn Header="MỨC" Binding="{Binding Severity}" Width="90"/></DataGrid.Columns></DataGrid><Button Grid.Row="2" Content="Đánh dấu đã xử lý" Command="{Binding AcknowledgeCommand}" Style="{StaticResource PrimaryButton}" Margin="18,12,18,16"/></Grid></Border></Grid></Grid><Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>