<UserControl x:Class="ExamTransfer.Desktop.Views.ExportCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0">
            <TextBlock Text="Xuất dữ liệu" Style="{StaticResource PageTitleText}" />
            <TextBlock Text="Tạo gói ZIP, manifest, biên nhận và audit theo phạm vi phiên thi."
                       Style="{StaticResource BodyText}" Margin="0,5,0,0" />
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.85*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Cấu hình export" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Phiên thi" Style="{StaticResource LabelText}" Margin="0,16,0,6" />
                    <ComboBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}" DisplayMemberPath="Title" />
                    <TextBlock Text="Quy tắc đặt tên" Style="{StaticResource LabelText}" Margin="0,12,0,6" />
                    <TextBox Text="{Binding NamingPattern}" />
                    <CheckBox Content="Bao gồm file bài nộp" IsChecked="{Binding IncludeFiles}" Margin="0,16,0,0" />
                    <CheckBox Content="Bao gồm manifest" IsChecked="{Binding IncludeManifest}" Margin="0,8,0,0" />
                    <CheckBox Content="Bao gồm biên nhận" IsChecked="{Binding IncludeReceipts}" Margin="0,8,0,0" />
                    <CheckBox Content="Bao gồm audit" IsChecked="{Binding IncludeAudit}" Margin="0,8,0,0" />
                    <Button Content="Tạo export job" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryButton}" Margin="0,18,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Tiến trình và lịch sử export" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="THỜI GIAN" Binding="{Binding CreatedAtUtc}" Width="150" />
                            <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="100" />
                            <DataGridTextColumn Header="TIẾN TRÌNH" Binding="{Binding Progress}" Width="90" />
                            <DataGridTextColumn Header="FILE" Binding="{Binding OutputFileName}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="18,12,18,16">
                        <Button Content="Cập nhật" Command="{Binding PollCommand}" Style="{StaticResource SecondaryButton}" />
                        <Button Content="Tải file" Command="{Binding DownloadCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" />
                        <Button Content="Hủy job" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}" FontSize="12" />
        </Border>
    </Grid>
</UserControl>