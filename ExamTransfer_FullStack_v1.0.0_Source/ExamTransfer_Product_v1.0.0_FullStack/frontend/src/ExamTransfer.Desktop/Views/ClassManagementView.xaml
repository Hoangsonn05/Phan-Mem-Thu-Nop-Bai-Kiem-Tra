<UserControl x:Class="ExamTransfer.Desktop.Views.ClassManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Quản lý lớp và học sinh"
                           Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Tạo lớp, cập nhật hồ sơ, quản lý học sinh và import danh sách có kiểm tra trước khi ghi dữ liệu."
                           Style="{StaticResource BodyText}"
                           Margin="0,5,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Làm mới"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Content="Xuất CSV"
                        Command="{Binding ExportCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" />
                <Button Content="Import CSV"
                        Command="{Binding ImportCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" />
                <Button Content="Tạo lớp"
                        Command="{Binding CreateCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Content: List + Detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Class list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="18,16,18,10">
                        <TextBlock Text="Danh sách lớp"
                                   Style="{StaticResource SectionTitleText}" />
                        <Button Content="Mở chi tiết"
                                Command="{Binding OpenCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Right"
                                MinHeight="34" />
                    </Grid>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Classes}"
                              SelectedItem="{Binding SelectedClass}"
                              Margin="0,0,0,4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ" Binding="{Binding Code}" Width="90" />
                            <DataGridTextColumn Header="TÊN LỚP" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="NĂM HỌC" Binding="{Binding SchoolYear}" Width="110" />
                            <DataGridTextColumn Header="HỌC SINH" Binding="{Binding StudentCount}" Width="85" />
                            <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Detail panel -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Class info -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Thông tin lớp"
                                       Style="{StaticResource SectionTitleText}" />
                            <TextBlock Text="Tên lớp *"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,16,0,6" />
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Mã lớp *" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding Code}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Năm học" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding SchoolYear}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Mô tả"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,12,0,6" />
                            <TextBox Text="{Binding Description}"
                                     Height="60"
                                     AcceptsReturn="True" />
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Lưu thay đổi"
                                        Command="{Binding SaveClassCommand}"
                                        Style="{StaticResource PrimaryButton}" />
                                <Button Content="Lưu trữ lớp"
                                        Command="{Binding ArchiveCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Add / update student -->
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="Thêm hoặc cập nhật học sinh"
                                       Style="{StaticResource SectionTitleText}" />
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Mã học sinh *" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding StudentCode}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Họ tên *" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                                    <TextBox Text="{Binding StudentName}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Email"
                                       Style="{StaticResource LabelText}"
                                       Margin="0,12,0,6" />
                            <TextBox Text="{Binding StudentEmail}" />
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Thêm mới"
                                        Command="{Binding AddStudentCommand}"
                                        Style="{StaticResource PrimaryButton}" />
                                <Button Content="Cập nhật"
                                        Command="{Binding UpdateStudentCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        Margin="8,0,0,0" />
                                <Button Content="Xóa khỏi lớp"
                                        Command="{Binding RemoveStudentCommand}"
                                        Style="{StaticResource DangerButton}"
                                        Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Student list in class -->
                    <Border Style="{StaticResource Card}" Margin="0,14,0,0" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="220" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Học sinh trong lớp"
                                       Style="{StaticResource SectionTitleText}"
                                       Margin="18,16,18,10" />
                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Students}"
                                      SelectedItem="{Binding SelectedStudent}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="MÃ" Binding="{Binding StudentCode}" Width="90" />
                                    <DataGridTextColumn Header="HỌ TÊN" Binding="{Binding DisplayName}" Width="*" />
                                    <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Style="{StaticResource StatusPill}"
                HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}"
                       Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>
