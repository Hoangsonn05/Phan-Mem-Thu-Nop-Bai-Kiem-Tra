<UserControl x:Class="ExamTransfer.Desktop.Views.BackupCenterView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="Sao lưu và khôi phục" Style="{StaticResource PageTitleText}"/><TextBlock Text="Tạo backup SQLite và file, kiểm tra checksum, tải xuống và khôi phục an toàn." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><CheckBox Content="Bao gồm file" IsChecked="{Binding IncludeFiles}" VerticalAlignment="Center"/><CheckBox Content="Mã hóa" IsChecked="{Binding Encrypt}" Margin="16,0,0,0" VerticalAlignment="Center"/><Button Content="Tạo backup" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryButton}" Margin="16,0,0,0"/></StackPanel></Grid><Border Grid.Row="2" Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid Margin="18,16,18,10"><TextBlock Text="Các bản sao lưu" Style="{StaticResource SectionTitleText}"/><Button Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" MinHeight="34"/></Grid><DataGrid Grid.Row="1" ItemsSource="{Binding Backups}" SelectedItem="{Binding SelectedBackup}"><DataGrid.Columns><DataGridTextColumn Header="FILE" Binding="{Binding FileName}" Width="*"/><DataGridTextColumn Header="THỜI GIAN" Binding="{Binding CreatedAtUtc}" Width="170"/><DataGridTextColumn Header="DUNG LƯỢNG" Binding="{Binding SizeBytes}" Width="110"/><DataGridTextColumn Header="SCHEMA" Binding="{Binding SchemaVersion}" Width="90"/><DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="110"/></DataGrid.Columns></DataGrid><StackPanel Grid.Row="2" Orientation="Horizontal" Margin="18,12,18,16"><Button Content="Kiểm tra checksum" Command="{Binding ValidateCommand}" Style="{StaticResource SecondaryButton}"/><Button Content="Tải backup" Command="{Binding DownloadCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/><Button Content="Khôi phục" Command="{Binding RestoreCommand}" Style="{StaticResource DangerButton}" Margin="8,0,0,0"/></StackPanel></Grid></Border><Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>