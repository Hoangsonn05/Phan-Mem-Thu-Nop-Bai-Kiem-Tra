<UserControl x:Class="ExamTransfer.Desktop.Views.SubmissionCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Trung tâm thu bài"
                           Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Theo dõi attempt, trạng thái xác minh, biên nhận và quyền nộp lại của từng học sinh."
                           Style="{StaticResource BodyText}"
                           Margin="0,5,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession}"
                          DisplayMemberPath="Title"
                          Width="260" />
                <Button Content="Tải bài nộp"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.75*" />
            </Grid.ColumnDefinitions>

            <!-- Submission list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Bài nộp theo phiên"
                               Style="{StaticResource SectionTitleText}"
                               Margin="18,16,18,10" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Submissions}"
                              SelectedItem="{Binding SelectedSubmission}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ" Binding="{Binding StudentCode}" Width="80" />
                            <DataGridTextColumn Header="HỌ TÊN" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="LẦN" Binding="{Binding AttemptNumber}" Width="55" />
                            <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="110" />
                            <DataGridCheckBoxColumn Header="MUỘN" Binding="{Binding IsLate}" Width="55" />
                            <DataGridTextColumn Header="BIÊN NHẬN" Binding="{Binding ReceiptCode}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Action panel -->
            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Xử lý bài nộp"
                                   Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Lý do"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,14,0,6" />
                        <TextBox Text="{Binding Reason}"
                                 Height="80"
                                 AcceptsReturn="True" />
                        <Button Content="Tải file đầu tiên"
                                Command="{Binding DownloadCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,14,0,0" />
                        <Button Content="Sao chép mã biên nhận"
                                Command="{Binding CopyReceiptCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,8,0,0" />
                        <Button Content="Cho nộp lại"
                                Command="{Binding ResubmitCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,8,0,0" />
                        <Button Content="Từ chối attempt"
                                Command="{Binding RejectCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource SubtleCard}" Margin="0,14,0,0">
                    <TextBlock Text="Mọi attempt được lưu append-only. Từ chối không xóa file cũ; nộp lại sẽ tạo attempt mới."
                               Style="{StaticResource BodyText}" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Style="{StaticResource StatusPill}"
                HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}"
                       Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>