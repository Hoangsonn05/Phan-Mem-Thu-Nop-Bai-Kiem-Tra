<UserControl x:Class="ExamTransfer.Desktop.Views.LiveMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Giám sát trực tiếp"
                           Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Snapshot từ REST kết hợp realtime để theo dõi kết nối, nhận đề, upload và bài nộp."
                           Style="{StaticResource BodyText}"
                           Margin="0,5,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession}"
                          DisplayMemberPath="RoomCode"
                          Width="160" />
                <Button Content="Tải phiên"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" />
                <Button Content="Làm mới"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="0.75*" />
            </Grid.ColumnDefinitions>

            <!-- Participant monitor -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Trạng thái học sinh"
                               Style="{StaticResource SectionTitleText}"
                               Margin="18,16,18,10" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Participants}"
                              SelectedItem="{Binding SelectedParticipant}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ" Binding="{Binding StudentCode}" Width="80" />
                            <DataGridTextColumn Header="HỌ TÊN" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="KẾT NỐI" Binding="{Binding ConnectionState}" Width="100" />
                            <DataGridTextColumn Header="NHẬN ĐỀ" Binding="{Binding DownloadStatus}" Width="100" />
                            <DataGridTextColumn Header="NỘP BÀI" Binding="{Binding SubmissionStatus}" Width="110" />
                            <DataGridTextColumn Header="THÊM PHÚT" Binding="{Binding ExtraTimeMinutes}" Width="75" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <WrapPanel Grid.Row="2" Margin="18,12,18,16">
                        <Button Content="Tạm dừng"
                                Command="{Binding PauseCommand}"
                                Style="{StaticResource SecondaryButton}" />
                        <Button Content="Tiếp tục"
                                Command="{Binding ResumeCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" />
                        <Button Content="Thu bài"
                                Command="{Binding CollectCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="8,0,0,0" />
                        <Button Content="Kết thúc"
                                Command="{Binding EndCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="8,0,0,0" />
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Quick actions + event feed -->
            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Thao tác nhanh"
                                   Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Thông báo"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,14,0,6" />
                        <TextBox Text="{Binding Message}"
                                 Height="84"
                                 AcceptsReturn="True" />
                        <Button Content="Gửi thông báo"
                                Command="{Binding MessageCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,10,0,0" />
                        <TextBlock Text="Cộng phút cho học sinh đã chọn"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,16,0,6" />
                        <TextBox Text="{Binding ExtraMinutes}" />
                        <Button Content="Áp dụng thời gian"
                                Command="{Binding ExtraTimeCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,14,0,0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Dòng sự kiện"
                                   Style="{StaticResource SectionTitleText}"
                                   Margin="18,16,18,10" />
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Events}"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,5">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13" />
                                        <TextBlock Text="{Binding Description}"
                                                   Style="{StaticResource CaptionText}"
                                                   Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding Time}"
                                                   Style="{StaticResource CaptionText}"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Style="{StaticResource StatusPill}"
                HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}"
                       Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>
