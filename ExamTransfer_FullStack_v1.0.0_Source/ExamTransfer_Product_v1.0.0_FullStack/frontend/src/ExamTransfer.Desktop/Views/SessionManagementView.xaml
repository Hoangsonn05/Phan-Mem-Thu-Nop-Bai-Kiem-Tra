<UserControl x:Class="ExamTransfer.Desktop.Views.SessionManagementView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="Quản lý phòng thi" Style="{StaticResource PageTitleText}"/><TextBlock Text="Tạo phòng từ bài kiểm tra đã phát hành và vận hành state machine của phiên thi." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><Button Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right"/></Grid><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Các phiên thi" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}"><DataGrid.Columns><DataGridTextColumn Header="PHÒNG" Binding="{Binding RoomCode}" Width="90"/><DataGridTextColumn Header="BÀI KIỂM TRA" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="110"/><DataGridTextColumn Header="KẾT NỐI" Binding="{Binding Counts.Connected}" Width="80"/><DataGridTextColumn Header="ĐÃ NỘP" Binding="{Binding Counts.Submitted}" Width="75"/></DataGrid.Columns></DataGrid><WrapPanel Grid.Row="2" Margin="18,12,18,16"><Button Content="Mở phòng" Command="{Binding OpenCommand}" Style="{StaticResource PrimaryButton}"/><Button Content="Bắt đầu" Command="{Binding StartCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/><Button Content="Tạm dừng" Command="{Binding PauseCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/><Button Content="Tiếp tục" Command="{Binding ResumeCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/><Button Content="Kết thúc" Command="{Binding EndCommand}" Style="{StaticResource DangerButton}" Margin="8,0,0,0"/></WrapPanel></Grid></Border><Border Grid.Column="2" Style="{StaticResource Card}"><StackPanel><TextBlock Text="Tạo phòng mới" Style="{StaticResource SectionTitleText}"/><TextBlock Text="Bài kiểm tra đã phát hành" Style="{StaticResource CaptionText}" Margin="0,14,0,5"/><ComboBox ItemsSource="{Binding Exams}" SelectedItem="{Binding SelectedExam}" DisplayMemberPath="Title"/><Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Mã phòng tùy chọn" Style="{StaticResource CaptionText}"/><TextBox Text="{Binding RoomCode}"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Sức chứa" Style="{StaticResource CaptionText}"/><TextBox Text="{Binding Capacity}"/></StackPanel></Grid><CheckBox Content="Tự động duyệt học sinh" IsChecked="{Binding AutoApprove}" Margin="0,14,0,0"/><Border Style="{StaticResource SubtleCard}" Margin="0,14,0,0"><TextBlock Text="Sau khi tạo, dùng nút Mở phòng để phát mã phòng và nhận yêu cầu tham gia trong mạng LAN." Style="{StaticResource BodyText}"/></Border><Button Content="Tạo phòng thi" Command="{Binding CreateCommand}" Style="{StaticResource PrimaryButton}" Margin="0,14,0,0"/></StackPanel></Border></Grid><Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>