<UserControl x:Class="ExamTransfer.Desktop.Views.SessionManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Quản lý phòng thi"
                           Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Tạo phòng từ bài kiểm tra đã phát hành và vận hành state machine của phiên thi."
                           Style="{StaticResource BodyText}"
                           Margin="0,5,0,0" />
            </StackPanel>
            <Button Content="Làm mới"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <!-- Session list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Các phiên thi"
                               Style="{StaticResource SectionTitleText}"
                               Margin="18,16,18,10" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Sessions}"
                              SelectedItem="{Binding SelectedSession}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PHÒNG" Binding="{Binding RoomCode}" Width="90" />
                            <DataGridTextColumn Header="BÀI KIỂM TRA" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="110" />
                            <DataGridTextColumn Header="PHẠM VI" Binding="{Binding AccessMode}" Width="100" />
                            <DataGridTextColumn Header="KẾT NỐI" Binding="{Binding Counts.Connected}" Width="80" />
                            <DataGridTextColumn Header="ĐÃ NỘP" Binding="{Binding Counts.Submitted}" Width="75" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <WrapPanel Grid.Row="2" Margin="18,12,18,16">
                        <Button Content="Mở phòng"
                                Command="{Binding OpenCommand}"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Content="Phân phối đề"
                                Command="{Binding DistributeCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" />
                        <Button Content="Bắt đầu"
                                Command="{Binding StartCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,0,0,0" />
                        <Button Content="Tạm dừng"
                                Command="{Binding PauseCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,4,0,0" />
                        <Button Content="Tiếp tục"
                                Command="{Binding ResumeCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,4,0,0" />
                        <Button Content="Thu bài"
                                Command="{Binding CollectCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Margin="8,4,0,0" />
                        <Button Content="Kết thúc"
                                Command="{Binding EndCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="8,4,0,0" />
                        <Button Content="Hủy phòng"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="8,4,0,0" />
                    </WrapPanel>
                </Grid>
            </Border>

            <!-- Create room panel -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Tạo phòng mới"
                               Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Bài kiểm tra đã phát hành"
                               Style="{StaticResource LabelText}"
                               Margin="0,16,0,6" />
                    <ComboBox ItemsSource="{Binding Exams}"
                              SelectedItem="{Binding SelectedExam}"
                              DisplayMemberPath="Title" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Mã phòng tùy chọn" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                            <TextBox Text="{Binding RoomCode}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Sức chứa" Style="{StaticResource LabelText}" Margin="0,0,0,6" />
                            <TextBox Text="{Binding Capacity}" />
                        </StackPanel>
                    </Grid>
                    <CheckBox Content="Tự động duyệt học sinh"
                              IsChecked="{Binding AutoApprove}"
                              Margin="0,16,0,0" />
                    <TextBlock Text="Phạm vi phiên thi"
                               Style="{StaticResource LabelText}"
                               Margin="0,12,0,6" />
                    <ComboBox ItemsSource="{Binding AccessModes}"
                              SelectedItem="{Binding AccessMode}" />
                    <Button Content="Lưu chế độ duyệt"
                            Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,12,0,0" />
                    <Border Style="{StaticResource SubtleCard}" Margin="0,16,0,0">
                        <TextBlock Text="Sau khi tạo, dùng nút Mở phòng để phát mã phòng và nhận yêu cầu tham gia trong mạng LAN."
                                   Style="{StaticResource BodyText}" />
                    </Border>
                    <Button Content="Tạo phòng thi"
                            Command="{Binding CreateCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,16,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Style="{StaticResource StatusPill}"
                HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}"
                       Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>
