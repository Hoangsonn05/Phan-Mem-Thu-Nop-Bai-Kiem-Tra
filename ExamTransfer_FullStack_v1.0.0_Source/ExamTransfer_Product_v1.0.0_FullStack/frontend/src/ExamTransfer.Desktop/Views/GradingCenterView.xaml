<UserControl x:Class="ExamTransfer.Desktop.Views.GradingCenterView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="Chấm bài" Style="{StaticResource PageTitleText}"/><TextBlock Text="Mở bài nộp chính thức, nhập điểm, rubric, nhận xét và công bố kết quả." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><Button Content="Làm mới hàng đợi" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right"/></Grid><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="0.95*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="Hàng đợi chấm" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Queue}" SelectedItem="{Binding SelectedSubmission}"><DataGrid.Columns><DataGridTextColumn Header="MÃ" Binding="{Binding StudentCode}" Width="85"/><DataGridTextColumn Header="HỌ TÊN" Binding="{Binding DisplayName}" Width="*"/><DataGridTextColumn Header="ATTEMPT" Binding="{Binding AttemptNumber}" Width="75"/><DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="110"/></DataGrid.Columns></DataGrid><Button Grid.Row="2" Content="Mở bài đã chọn" Command="{Binding OpenCommand}" Style="{StaticResource PrimaryButton}" Margin="18,12,18,16"/></Grid></Border><ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"><StackPanel><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Điểm và nhận xét" Style="{StaticResource SectionTitleText}"/><Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Điểm" Style="{StaticResource CaptionText}"/><TextBox Text="{Binding Score}"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Thang điểm" Style="{StaticResource CaptionText}"/><TextBox Text="{Binding MaxScore}"/></StackPanel></Grid><TextBlock Text="Nhận xét chung" Style="{StaticResource CaptionText}" Margin="0,10,0,5"/><TextBox Text="{Binding Comment}" Height="110" AcceptsReturn="True"/><Button Content="Lưu điểm" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0"/><Button Content="Trả kết quả" Command="{Binding ReturnCommand}" Style="{StaticResource SecondaryButton}" Margin="0,8,0,0"/><Button Content="Mở lại để chỉnh sửa" Command="{Binding ReopenCommand}" Style="{StaticResource SecondaryButton}" Margin="0,8,0,0"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,14,0,0" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="180"/></Grid.RowDefinitions><TextBlock Text="Rubric" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Rubric}"><DataGrid.Columns><DataGridTextColumn Header="TIÊU CHÍ" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="ĐIỂM" Binding="{Binding Score}" Width="70"/><DataGridTextColumn Header="TỐI ĐA" Binding="{Binding MaxScore}" Width="70"/></DataGrid.Columns></DataGrid></Grid></Border></StackPanel></ScrollViewer></Grid><Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>