<UserControl x:Class="ExamTransfer.Desktop.Views.LobbyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Phòng chờ giáo viên"
                           Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Duyệt danh tính, kiểm tra thiết bị và bắt đầu phiên khi checklist đã sẵn sàng."
                           Style="{StaticResource BodyText}"
                           Margin="0,5,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession}"
                          DisplayMemberPath="RoomCode"
                          Width="160" />
                <Button Content="Tải phòng"
                        Command="{Binding LoadSessionCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="8,0,0,0" />
                <Button Content="Bắt đầu phiên"
                        Command="{Binding StartCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="8,0,0,0" />
            </StackPanel>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="0.75*" />
            </Grid.ColumnDefinitions>

            <!-- Participant list -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="18,16,18,10">
                        <TextBlock Text="Yêu cầu tham gia"
                                   Style="{StaticResource SectionTitleText}" />
                        <Button Content="Duyệt tất cả"
                                Command="{Binding BulkApproveCommand}"
                                Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Right"
                                MinHeight="34" />
                    </Grid>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Participants}"
                              SelectedItem="{Binding SelectedParticipant}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MÃ" Binding="{Binding StudentCode}" Width="85" />
                            <DataGridTextColumn Header="HỌ TÊN" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="MÁY" Binding="{Binding MachineName}" Width="120" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="110" />
                            <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="18,12,18,16">
                        <Button Content="Duyệt"
                                Command="{Binding ApproveCommand}"
                                Style="{StaticResource PrimaryButton}" />
                        <Button Content="Từ chối"
                                Command="{Binding RejectCommand}"
                                Style="{StaticResource DangerButton}"
                                Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sidebar tools -->
            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Thông báo phòng chờ"
                                   Style="{StaticResource SectionTitleText}" />
                        <TextBox Text="{Binding Message}"
                                 Height="100"
                                 AcceptsReturn="True"
                                 Margin="0,14,0,0" />
                        <Button Content="Gửi thông báo"
                                Command="{Binding MessageCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Checklist trước khi bắt đầu"
                                   Style="{StaticResource SectionTitleText}" />
                        <StackPanel Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE73E;"
                                           Style="{StaticResource IconText}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Danh tính học sinh đã được duyệt"
                                           Style="{StaticResource BodyText}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE73E;"
                                           Style="{StaticResource IconText}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Thiết bị có quyền ghi và đủ dung lượng"
                                           Style="{StaticResource BodyText}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="&#xE73E;"
                                           Style="{StaticResource IconText}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Đề đã phát hành và có manifest hợp lệ"
                                           Style="{StaticResource BodyText}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;"
                                           Style="{StaticResource IconText}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Chính sách kiểm soát đã được xác nhận"
                                           Style="{StaticResource BodyText}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="4"
                Style="{StaticResource StatusPill}"
                HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}"
                       Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                       FontSize="12" />
        </Border>
    </Grid>
</UserControl>