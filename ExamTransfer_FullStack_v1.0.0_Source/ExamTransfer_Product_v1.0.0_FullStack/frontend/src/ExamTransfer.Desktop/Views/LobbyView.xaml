<UserControl x:Class="ExamTransfer.Desktop.Views.LobbyView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="Phòng chờ giáo viên" Style="{StaticResource PageTitleText}"/><TextBlock Text="Duyệt danh tính, kiểm tra thiết bị và bắt đầu phiên khi checklist đã sẵn sàng." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><ComboBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}" DisplayMemberPath="RoomCode" Width="150"/><Button Content="Tải phòng" Command="{Binding LoadSessionCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/><Button Content="Bắt đầu phiên" Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel></Grid><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.35*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="0.75*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid Margin="18,16,18,10"><TextBlock Text="Yêu cầu tham gia" Style="{StaticResource SectionTitleText}"/><Button Content="Duyệt tất cả" Command="{Binding BulkApproveCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" MinHeight="34"/></Grid><DataGrid Grid.Row="1" ItemsSource="{Binding Participants}" SelectedItem="{Binding SelectedParticipant}"><DataGrid.Columns><DataGridTextColumn Header="MÃ" Binding="{Binding StudentCode}" Width="85"/><DataGridTextColumn Header="HỌ TÊN" Binding="{Binding DisplayName}" Width="*"/><DataGridTextColumn Header="MÁY" Binding="{Binding MachineName}" Width="120"/><DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="110"/><DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="120"/></DataGrid.Columns></DataGrid><StackPanel Grid.Row="2" Orientation="Horizontal" Margin="18,12,18,16"><Button Content="Duyệt" Command="{Binding ApproveCommand}" Style="{StaticResource PrimaryButton}"/><Button Content="Từ chối" Command="{Binding RejectCommand}" Style="{StaticResource DangerButton}" Margin="8,0,0,0"/></StackPanel></Grid></Border><StackPanel Grid.Column="2"><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="Thông báo phòng chờ" Style="{StaticResource SectionTitleText}"/><TextBox Text="{Binding Message}" Height="100" AcceptsReturn="True" Margin="0,12,0,0"/><Button Content="Gửi thông báo" Command="{Binding MessageCommand}" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0"/></StackPanel></Border><Border Style="{StaticResource Card}" Margin="0,14,0,0"><StackPanel><TextBlock Text="Checklist trước khi bắt đầu" Style="{StaticResource SectionTitleText}"/><TextBlock Text="• Danh tính học sinh đã được duyệt" Style="{StaticResource BodyText}" Margin="0,12,0,0"/><TextBlock Text="• Thiết bị có quyền ghi và đủ dung lượng" Style="{StaticResource BodyText}"/><TextBlock Text="• Đề đã phát hành và có manifest hợp lệ" Style="{StaticResource BodyText}"/><TextBlock Text="• Chính sách kiểm soát đã được xác nhận" Style="{StaticResource BodyText}"/></StackPanel></Border></StackPanel></Grid><Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>