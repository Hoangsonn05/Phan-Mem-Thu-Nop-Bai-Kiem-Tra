<UserControl x:Class="ExamTransfer.Desktop.Views.StudentSubmissionView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="24"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Nộp bài" Style="{StaticResource PageTitleText}"/><TextBlock Text="Kiểm tra file, khởi tạo attempt, tải theo chunk, finalize và chờ máy chủ xác nhận." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions><Border Style="{StaticResource Card}"><StackPanel><TextBlock Text="File bài làm" Style="{StaticResource SectionTitleText}"/><TextBlock Text="{Binding SelectedPath, TargetNullValue=Chưa chọn file}" Style="{StaticResource BodyText}" Margin="0,16,0,0"/><Button Content="Chọn file bài làm" Command="{Binding PickCommand}" Style="{StaticResource SecondaryButton}" Margin="0,14,0,0"/><ProgressBar Value="{Binding Progress}" Height="10" Margin="0,20,0,0"/><TextBlock Text="{Binding Progress, StringFormat={}{0:N0}%}" HorizontalAlignment="Right" Style="{StaticResource CaptionText}" Margin="0,5,0,0"/><Button Content="Bắt đầu nộp bài" Command="{Binding SubmitCommand}" Style="{StaticResource PrimaryButton}" Margin="0,18,0,0"/></StackPanel></Border><Border Grid.Column="2" Style="{StaticResource Card}"><StackPanel><TextBlock Text="Quy trình xác nhận" Style="{StaticResource SectionTitleText}"/><TextBlock Text="1. Tính SHA-256 trên máy học sinh" Style="{StaticResource BodyText}" Margin="0,16,0,0"/><TextBlock Text="2. Máy chủ tạo attempt và kế hoạch chunk" Style="{StaticResource BodyText}" Margin="0,8,0,0"/><TextBlock Text="3. Gửi từng chunk và có thể tiếp tục khi mất mạng" Style="{StaticResource BodyText}" Margin="0,8,0,0"/><TextBlock Text="4. Finalize, xác minh toàn file và tạo biên nhận" Style="{StaticResource BodyText}" Margin="0,8,0,0"/><Border Style="{StaticResource SubtleCard}" Margin="0,20,0,0"><TextBlock Text="Không đóng ứng dụng cho đến khi mục Biên nhận hiển thị mã xác nhận từ máy chủ." Style="{StaticResource BodyText}"/></Border></StackPanel></Border></Grid><Border Grid.Row="3" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>