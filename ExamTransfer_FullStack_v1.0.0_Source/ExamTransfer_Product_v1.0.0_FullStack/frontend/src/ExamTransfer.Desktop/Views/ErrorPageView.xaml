<UserControl x:Class="ExamTransfer.Desktop.Views.ErrorPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="30" Background="{DynamicResource AppBackgroundBrush}">
        <Border Style="{StaticResource Card}"
                MaxWidth="720"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="32,28">
            <StackPanel>
                <Border Width="60"
                        Height="60"
                        CornerRadius="18"
                        Background="{DynamicResource DangerSoftBrush}"
                        HorizontalAlignment="Left">
                    <TextBlock Text="&#xEA39;"
                               Style="{StaticResource IconText}"
                               FontSize="26"
                               Foreground="{DynamicResource DangerBrush}" />
                </Border>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource PageTitleText}"
                           Margin="0,18,0,0" />
                <TextBlock Text="{Binding Message}"
                           Style="{StaticResource BodyText}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap" />
                <Border Style="{StaticResource SubtleCard}" Margin="0,20,0,0" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="{Binding TraceId, StringFormat=Trace ID: {0}}"
                                   Style="{StaticResource CaptionText}"
                                   FontFamily="Consolas" />
                        <TextBlock Text="{Binding LogPath}"
                                   Style="{StaticResource CaptionText}"
                                   FontFamily="Consolas"
                                   Margin="0,5,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <Button Content="Thử lại"
                            Command="{Binding RetryCommand}"
                            Style="{StaticResource PrimaryButton}" />
                    <Button Content="Quay về trang chọn chế độ"
                            Command="{Binding GoHomeCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="10,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
