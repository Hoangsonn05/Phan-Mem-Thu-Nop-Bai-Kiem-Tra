<UserControl x:Class="ExamTransfer.Desktop.Views.ErrorPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="30">
        <Border Style="{StaticResource Card}" MaxWidth="720" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="{Binding Message}" Style="{StaticResource BodyText}" Margin="0,8,0,0" />
                <Border Style="{StaticResource SubtleCard}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding TraceId, StringFormat=Trace ID: {0}}" Style="{StaticResource CaptionText}" FontFamily="Consolas" />
                        <TextBlock Text="{Binding LogPath}" Style="{StaticResource CaptionText}" FontFamily="Consolas" Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Content="Thử lại" Command="{Binding RetryCommand}" Style="{StaticResource PrimaryButton}" />
                    <Button Content="Quay về trang chọn chế độ" Command="{Binding GoHomeCommand}" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
