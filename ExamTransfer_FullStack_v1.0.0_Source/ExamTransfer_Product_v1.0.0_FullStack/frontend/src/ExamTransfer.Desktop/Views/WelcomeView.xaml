<UserControl x:Class="ExamTransfer.Desktop.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="22" Padding="40" Effect="{StaticResource FloatingShadow}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1D4ED8" Offset="0" />
                        <GradientStop Color="#2563EB" Offset="0.48" />
                        <GradientStop Color="#0891B2" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.3*" />
                        <ColumnDefinition Width="0.7*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MaxWidth="700" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Border HorizontalAlignment="Left" Padding="10,5" CornerRadius="999" Background="#2AFFFFFF">
                            <TextBlock Text="LOCAL-FIRST · WINDOWS DESKTOP" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <TextBlock Text="{Binding Title}" Margin="0,18,0,6" FontSize="42" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="{Binding Description}" MaxWidth="640" FontSize="18" LineHeight="28" Foreground="#EAF2FF" />
                        <TextBlock Text="Chọn chế độ Giáo viên hoặc Học sinh ở thanh bên để bắt đầu. Dữ liệu phòng thi vẫn hoạt động trong LAN khi không có Internet."
                                   Margin="0,14,0,24" MaxWidth="650" FontSize="14" LineHeight="22" Foreground="#D8E8FF" />
                        <StackPanel Orientation="Horizontal">
                            <Border Padding="12,8" CornerRadius="9" Background="White">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" Style="{StaticResource IconText}" Foreground="#15803D" />
                                    <TextBlock Text="Hợp đồng API sẵn sàng" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="#0F172A" />
                                </StackPanel>
                            </Border>
                            <Border Margin="10,0,0,0" Padding="12,8" CornerRadius="9" Background="#26FFFFFF">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" Style="{StaticResource IconText}" Foreground="White" />
                                    <TextBlock Text="Bảo mật theo phiên" Margin="8,0,0,0" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Center">
                        <Border Width="250" Height="250" CornerRadius="125" Background="#15FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border Width="190" Height="190" CornerRadius="95" Background="#20FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border Width="118" Height="118" CornerRadius="30" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Effect="{StaticResource FloatingShadow}">
                            <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" FontSize="54" Foreground="#2563EB" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Benefits}" Margin="0,24,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,14,0">
                            <StackPanel>
                                <Border Width="44" Height="44" HorizontalAlignment="Left" CornerRadius="12"
                                        Background="{Binding Tone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                                    <TextBlock Text="{Binding Glyph}" Style="{StaticResource IconText}" FontSize="20"
                                               Foreground="{Binding Tone, Converter={StaticResource ToneBrushConverter}}" />
                                </Border>
                                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleText}" Margin="0,16,0,6" />
                                <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="2" Style="{StaticResource SubtleCard}" Margin="0,24,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" CornerRadius="12" Background="{DynamicResource PrimarySoftBrush}">
                        <TextBlock Text="&#xE946;" Style="{StaticResource IconText}" Foreground="{DynamicResource PrimaryBrush}" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="14,0">
                        <TextBlock Text="Kiểm tra hệ thống" Style="{StaticResource CardTitleText}" />
                        <TextBlock Text="Ứng dụng kiểm tra kết nối, thư mục dữ liệu, quyền ghi và trạng thái phòng thi trước khi vận hành." Style="{StaticResource BodyText}" Margin="0,3,0,0" />
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text=".NET 10 · WPF · SQLite · Local-first" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
