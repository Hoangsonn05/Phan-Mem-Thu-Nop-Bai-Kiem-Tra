<Window x:Class="ExamTransfer.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ExamTransfer.Desktop.ViewModels"
        xmlns:views="clr-namespace:ExamTransfer.Desktop.Views"
        xmlns:models="clr-namespace:ExamTransfer.Desktop.Models"
        Title="ExamTransfer - Thu và gửi bài kiểm tra"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <CollectionViewSource x:Key="GroupedNavigation" Source="{Binding Navigation}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Group" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <DataTemplate DataType="{x:Type vm:LoginViewModel}"><views:LoginView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChangePasswordViewModel}"><views:ChangePasswordView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClassManagementViewModel}"><views:ClassManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExamManagementViewModel}"><views:ExamManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionManagementViewModel}"><views:SessionManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LobbyViewModel}"><views:LobbyView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveMonitorViewModel}"><views:LiveMonitorView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SubmissionCenterViewModel}"><views:SubmissionCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExportCenterViewModel}"><views:ExportCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GradingCenterViewModel}"><views:GradingCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ControlCenterViewModel}"><views:ControlCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryAuditViewModel}"><views:HistoryAuditView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupCenterViewModel}"><views:BackupCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsPageViewModel}"><views:SettingsPageView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentHomeViewModel}"><views:StudentHomeView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentConnectViewModel}"><views:StudentConnectView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentWaitingViewModel}"><views:StudentWaitingView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentExamViewModel}"><views:StudentExamView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentDownloadViewModel}"><views:StudentDownloadView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentQuizViewModel}"><views:StudentQuizView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentSubmissionViewModel}"><views:StudentSubmissionView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentReceiptViewModel}"><views:StudentReceiptView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentHistoryViewModel}"><views:StudentHistoryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentSettingsViewModel}"><views:StudentSettingsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ErrorPageViewModel}"><views:ErrorPageView /></DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <!-- Sidebar 240px – compact hơn 264px cũ -->
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             SIDEBAR – Slate dark, không phải blue gradient
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Brand: compact, không có card nổi -->
            <Border Grid.Row="0" Padding="16,18,16,14">
                <StackPanel Orientation="Horizontal">
                    <Border Width="34" Height="34" CornerRadius="9">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D9488" Offset="0" />
                                <GradientStop Color="#0891B2" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="&#xE8A5;"
                                   Style="{StaticResource IconText}"
                                   FontSize="16"
                                   Foreground="White" />
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ExamTransfer"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SidebarTextBrush}" />
                        <TextBlock Text="EXAM SUITE"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SidebarMutedBrush}"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Account panel: compact inline -->
            <Border Grid.Row="1"
                    Margin="10,0,10,10"
                    Padding="10,9"
                    CornerRadius="8"
                    Background="#12FFFFFF">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding AccountDisplay}"
                                   Foreground="{DynamicResource SidebarTextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <TextBlock Text="{Binding AccountRole}"
                                   Foreground="{DynamicResource SidebarMutedBrush}"
                                   FontSize="11"
                                   Margin="0,1,0,0" />
                        <TextBlock Text="{Binding SessionStatusText}"
                                   Foreground="{DynamicResource SidebarMutedBrush}"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   Margin="0,1,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding LogoutCommand}"
                            Style="{StaticResource GhostButton}"
                            ToolTip="Đăng xuất"
                            AutomationProperties.Name="Đăng xuất"
                            MinWidth="30"
                            MinHeight="30"
                            Padding="5">
                        <TextBlock Text="&#xF3B1;"
                                   Style="{StaticResource IconText}"
                                   FontSize="14"
                                   Foreground="{DynamicResource SidebarMutedBrush}" />
                    </Button>
                </Grid>
            </Border>

            <!-- Navigation List -->
            <ListBox Grid.Row="2"
                     Style="{StaticResource SidebarListBox}"
                     ItemContainerStyle="{StaticResource SidebarItem}"
                     ItemsSource="{Binding Source={StaticResource GroupedNavigation}}"
                     SelectedItem="{Binding Selected, Mode=TwoWay}">
                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           Margin="16,12,12,4"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SidebarMutedBrush}"
                                           TextWrapping="NoWrap" />
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:NavigationItem}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Glyph}"
                                       Style="{StaticResource IconText}"
                                       Width="20" Height="20"
                                       FontSize="14"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Title}"
                                       Margin="8,0,5,0"
                                       VerticalAlignment="Center"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" />
                            <Border Grid.Column="2"
                                    CornerRadius="999"
                                    Padding="5,2"
                                    Background="{DynamicResource SidebarBadgeBrush}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Badge}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Badge}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Badge}"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource SidebarTextBrush}"
                                           TextWrapping="NoWrap" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Bottom: Mode + Theme toggle – compact -->
            <Border Grid.Row="3"
                    Margin="10,6,10,14"
                    Padding="10,8"
                    CornerRadius="8"
                    Background="#0EFFFFFF">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Mode icon -->
                    <Border Width="28" Height="28" CornerRadius="7">
                        <Border.Background>
                            <SolidColorBrush Color="#1AFFFFFF" />
                        </Border.Background>
                        <TextBlock Text="ET"
                                   Foreground="{DynamicResource SidebarTextBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" Margin="9,0,6,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ModeTitle}"
                                   Foreground="{DynamicResource SidebarTextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />
                        <TextBlock Text="{Binding EnvironmentLabel}"
                                   Foreground="{DynamicResource SidebarMutedBrush}"
                                   FontSize="9" />
                    </StackPanel>
                    <!-- Theme toggle -->
                    <Button Grid.Column="2"
                            Command="{Binding ToggleThemeCommand}"
                            Style="{StaticResource GhostButton}"
                            ToolTip="{Binding ThemeLabel}"
                            MinWidth="30" MinHeight="30"
                            Padding="5">
                        <TextBlock Text="&#xE706;"
                                   Style="{StaticResource IconText}"
                                   FontSize="13"
                                   Foreground="{DynamicResource SidebarMutedBrush}" />
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             MAIN CONTENT AREA
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Header compact 56px thay vì 68px -->
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header bar: phân cách bằng border đáy, không shadow -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Page identity: icon + title + description inline -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageGlyph}"
                                   Style="{StaticResource IconText}"
                                   FontSize="16"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding PageTitle}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap" />
                            <TextBlock Text="{Binding PageDescription}"
                                       Style="{StaticResource CaptionText}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Connection status + refresh -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusPill}"
                                Background="{Binding ConnectionTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6"
                                         Fill="{Binding ConnectionTone, Converter={StaticResource ToneBrushConverter}}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Connection}"
                                           Margin="6,0,0,0"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding ConnectionTone, Converter={StaticResource ToneBrushConverter}}" />
                            </StackPanel>
                        </Border>
                        <Button Command="{Binding RefreshCommand}"
                                Style="{StaticResource GhostButton}"
                                Margin="5,0,0,0"
                                ToolTip="Kiểm tra lại kết nối"
                                AutomationProperties.Name="Kiểm tra lại kết nối">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
