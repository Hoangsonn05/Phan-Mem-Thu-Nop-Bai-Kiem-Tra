<UserControl x:Class="ExamTransfer.Desktop.Views.HistoryAuditView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid Margin="32"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid><StackPanel><TextBlock Text="Lịch sử và Audit" Style="{StaticResource PageTitleText}"/><TextBlock Text="Tra cứu phiên đã kết thúc và nhật ký bất biến theo actor, action, trace ID và thời gian." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><TextBox Text="{Binding Search}" Width="240"/><Button Content="Làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/><Button Content="Xuất audit" Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/></StackPanel></Grid><Grid Grid.Row="2"><Grid.RowDefinitions><RowDefinition Height="0.9*"/><RowDefinition Height="14"/><RowDefinition Height="1.1*"/></Grid.RowDefinitions><Border Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="Phiên thi" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Sessions}"><DataGrid.Columns><DataGridTextColumn Header="PHÒNG" Binding="{Binding RoomCode}" Width="90"/><DataGridTextColumn Header="BÀI KIỂM TRA" Binding="{Binding Title}" Width="*"/><DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="110"/><DataGridTextColumn Header="BẮT ĐẦU" Binding="{Binding StartTimeUtc}" Width="160"/><DataGridTextColumn Header="ĐÃ NỘP" Binding="{Binding Counts.Submitted}" Width="70"/></DataGrid.Columns></DataGrid></Grid></Border><Border Grid.Row="2" Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="Audit log" Style="{StaticResource SectionTitleText}" Margin="18,16,18,10"/><DataGrid Grid.Row="1" ItemsSource="{Binding Audits}"><DataGrid.Columns><DataGridTextColumn Header="THỜI GIAN" Binding="{Binding CreatedAtUtc}" Width="165"/><DataGridTextColumn Header="ACTOR" Binding="{Binding ActorId}" Width="120"/><DataGridTextColumn Header="HÀNH ĐỘNG" Binding="{Binding Action}" Width="160"/><DataGridTextColumn Header="ĐỐI TƯỢNG" Binding="{Binding EntityType}" Width="120"/><DataGridTextColumn Header="TRACE ID" Binding="{Binding TraceId}" Width="*"/></DataGrid.Columns></DataGrid></Grid></Border></Grid><Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}"><TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"/></Border></Grid></UserControl>