<UserControl x:Class="ExamTransfer.Desktop.Views.StudentHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Lịch sử trên thiết bị" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Các phiên, bài đã nộp và mã biên nhận thuộc hồ sơ hiện tại."
                           Style="{StaticResource BodyText}" Margin="0,5,0,0" />
            </StackPanel>
            <Button Content="Làm mới" Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding History}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PHÒNG" Binding="{Binding RoomCode}" Width="120" />
                    <DataGridTextColumn Header="BIÊN NHẬN" Binding="{Binding ReceiptCode}" Width="*" />
                    <DataGridTextColumn Header="THỜI GIAN" Binding="{Binding SubmittedAt}" Width="180" />
                    <DataGridTextColumn Header="TRẠNG THÁI" Binding="{Binding Status}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left"
                Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}" FontSize="12" />
        </Border>
    </Grid>
</UserControl>