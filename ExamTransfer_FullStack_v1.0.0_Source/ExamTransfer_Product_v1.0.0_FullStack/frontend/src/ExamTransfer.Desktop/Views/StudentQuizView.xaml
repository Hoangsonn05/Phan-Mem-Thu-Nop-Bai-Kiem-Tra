<UserControl x:Class="ExamTransfer.Desktop.Views.StudentQuizView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid>
            <StackPanel><TextBlock Text="Thi trắc nghiệm" Style="{StaticResource PageTitleText}"/><TextBlock Text="Đáp án được lưu cục bộ trước, đồng bộ theo revision và chấm trên máy chủ." Style="{StaticResource BodyText}" Margin="0,5,0,0"/></StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Mở / làm mới" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}"/><Button Content="Đồng bộ" Command="{Binding SyncCommand}" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0"/><Button Content="Chốt bài" Command="{Binding FinalizeCommand}" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/></StackPanel>
        </Grid>
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Questions}">
                <ItemsControl.ItemTemplate><DataTemplate><Border Style="{StaticResource Card}" Margin="0,0,0,12"><StackPanel><TextBlock><Run Text="Câu "/><Run Text="{Binding Order}"/><Run Text=" · "/><Run Text="{Binding Points}"/><Run Text=" điểm"/></TextBlock><TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontWeight="SemiBold" FontSize="15" Margin="0,8,0,10"/><ItemsControl ItemsSource="{Binding Choices}"><ItemsControl.ItemTemplate><DataTemplate><CheckBox Content="{Binding Text}" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Border Grid.Row="4" Style="{StaticResource StatusPill}" HorizontalAlignment="Left"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding Result}"/><TextBlock Text=" · "/><TextBlock Text="{Binding Status}"/></StackPanel></Border>
    </Grid>
</UserControl>
