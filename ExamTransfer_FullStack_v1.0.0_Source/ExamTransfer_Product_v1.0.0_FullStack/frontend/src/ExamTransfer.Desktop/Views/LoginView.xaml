<UserControl x:Class="ExamTransfer.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="32">
        <Border Style="{StaticResource Card}"
                MaxWidth="590"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="30">
            <StackPanel>
                <Border Width="60"
                        Height="60"
                        CornerRadius="18"
                        Background="{DynamicResource PrimarySoftBrush}"
                        HorizontalAlignment="Left">
                    <TextBlock Text="&#xE8D7;"
                               Style="{StaticResource IconText}"
                               FontSize="27"
                               Foreground="{DynamicResource PrimaryBrush}" />
                </Border>

                <TextBlock Text="Đăng nhập ExamTransfer"
                           Style="{StaticResource DisplayTitleText}"
                           Margin="0,18,0,6" />
                <TextBlock Text="Hệ thống tự xác định giao diện phù hợp theo vai trò của tài khoản."
                           Style="{StaticResource BodyText}" />

                <Border Style="{StaticResource SubtleCard}" Margin="0,20,0,0" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE77B;"
                                   Style="{StaticResource IconText}"
                                   FontSize="17"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   VerticalAlignment="Top"
                                   Margin="0,2,10,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Học sinh" FontWeight="SemiBold" />
                            <TextBlock Text="Nhập mã sinh viên và mật khẩu được cấp."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />
                            <TextBlock Text="Giáo viên / Quản trị viên"
                                       FontWeight="SemiBold"
                                       Margin="0,9,0,0" />
                            <TextBlock Text="Nhập email tài khoản và mật khẩu."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Mã sinh viên hoặc email"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Margin="0,22,0,0" />
                <TextBox Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,6,0,14"
                         ToolTip="Ví dụ: 23174800110 hoặc admin@domain.com" />

                <TextBlock Text="Mật khẩu" FontWeight="SemiBold" FontSize="12" />
                <PasswordBox x:Name="PasswordInput"
                             PasswordChanged="OnPasswordChanged"
                             Margin="0,6,0,0" />

                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,20,0,0"
                        MinHeight="44"
                        Content="Đăng nhập" />

                <Border Style="{StaticResource StatusPill}"
                        HorizontalAlignment="Left"
                        Margin="0,18,0,0"
                        Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                    <TextBlock Text="{Binding Status}"
                               Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="{Binding DeviceId, StringFormat=Device ID: {0}}"
                           Style="{StaticResource CaptionText}"
                           Margin="0,14,0,0"
                           FontFamily="Consolas" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
