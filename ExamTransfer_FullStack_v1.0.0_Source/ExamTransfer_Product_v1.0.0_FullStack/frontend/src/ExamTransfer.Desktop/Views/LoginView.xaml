<UserControl x:Class="ExamTransfer.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <!-- Centered login – dùng toàn bộ vùng content, nền app background -->
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Login card – căn giữa, shadow nhẹ -->
        <Border Grid.Row="1"
                Style="{StaticResource Card}"
                MaxWidth="460"
                HorizontalAlignment="Center"
                Padding="36,32"
                Effect="{StaticResource FloatingShadow}">
            <StackPanel>

                <!-- Brand icon -->
                <Border Width="52" Height="52" CornerRadius="14" HorizontalAlignment="Left">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0D9488" Offset="0" />
                            <GradientStop Color="#0891B2" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="&#xE8D7;"
                               Style="{StaticResource IconText}"
                               FontSize="22"
                               Foreground="White" />
                </Border>

                <!-- Title -->
                <TextBlock Text="Đăng nhập ExamTransfer"
                           Style="{StaticResource DisplayTitleText}"
                           Margin="0,16,0,5" />
                <TextBlock Text="Hệ thống tự xác định giao diện phù hợp theo vai trò của tài khoản."
                           Style="{StaticResource BodyText}" />

                <!-- Info box -->
                <Border Style="{StaticResource SubtleCard}"
                        Margin="0,18,0,0"
                        Padding="13,11">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE77B;"
                                   Style="{StaticResource IconText}"
                                   FontSize="15"
                                   Foreground="{DynamicResource InfoBrush}"
                                   VerticalAlignment="Top"
                                   Margin="0,2,10,0" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Học sinh"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <TextBlock Text="Nhập mã sinh viên và mật khẩu được cấp."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />
                            <TextBlock Text="Giáo viên / Quản trị viên"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Margin="0,9,0,0" />
                            <TextBlock Text="Nhập email tài khoản và mật khẩu."
                                       Style="{StaticResource CaptionText}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Username field -->
                <TextBlock Text="Mã sinh viên hoặc email"
                           Style="{StaticResource LabelText}"
                           Margin="0,20,0,6" />
                <TextBox Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Ví dụ: 23174800110 hoặc admin@domain.com"
                         Margin="0,0,0,14" />

                <!-- Password field -->
                <TextBlock Text="Mật khẩu"
                           Style="{StaticResource LabelText}"
                           Margin="0,0,0,6" />
                <PasswordBox x:Name="PasswordInput"
                             PasswordChanged="OnPasswordChanged" />

                <!-- Login button -->
                <Button Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,18,0,0"
                        MinHeight="42"
                        Content="Đăng nhập" />

                <!-- Status feedback -->
                <Border Style="{StaticResource StatusPill}"
                        HorizontalAlignment="Left"
                        Margin="0,16,0,0"
                        Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                    <TextBlock Text="{Binding Status}"
                               Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}"
                               TextWrapping="Wrap"
                               FontSize="13" />
                </Border>

                <!-- Device ID -->
                <TextBlock Text="{Binding DeviceId, StringFormat=Device ID: {0}}"
                           Style="{StaticResource CaptionText}"
                           Margin="0,13,0,0"
                           FontFamily="Consolas" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
