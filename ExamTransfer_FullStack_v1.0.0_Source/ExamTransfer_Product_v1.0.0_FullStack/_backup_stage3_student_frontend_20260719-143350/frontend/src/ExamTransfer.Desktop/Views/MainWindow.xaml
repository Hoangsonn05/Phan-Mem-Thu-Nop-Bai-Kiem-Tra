<Window x:Class="ExamTransfer.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ExamTransfer.Desktop.ViewModels"
        xmlns:views="clr-namespace:ExamTransfer.Desktop.Views"
        xmlns:models="clr-namespace:ExamTransfer.Desktop.Models"
        Title="ExamTransfer - Thu và gửi bài kiểm tra"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <CollectionViewSource x:Key="GroupedNavigation" Source="{Binding Navigation}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Group" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <DataTemplate DataType="{x:Type vm:LoginViewModel}"><views:LoginView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:WelcomeViewModel}"><views:WelcomeView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClassManagementViewModel}"><views:ClassManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExamManagementViewModel}"><views:ExamManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionManagementViewModel}"><views:SessionManagementView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LobbyViewModel}"><views:LobbyView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveMonitorViewModel}"><views:LiveMonitorView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SubmissionCenterViewModel}"><views:SubmissionCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExportCenterViewModel}"><views:ExportCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:GradingCenterViewModel}"><views:GradingCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ControlCenterViewModel}"><views:ControlCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryAuditViewModel}"><views:HistoryAuditView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:BackupCenterViewModel}"><views:BackupCenterView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsPageViewModel}"><views:SettingsPageView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentConnectViewModel}"><views:StudentConnectView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentWaitingViewModel}"><views:StudentWaitingView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentExamViewModel}"><views:StudentExamView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentDownloadViewModel}"><views:StudentDownloadView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentSubmissionViewModel}"><views:StudentSubmissionView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentReceiptViewModel}"><views:StudentReceiptView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentHistoryViewModel}"><views:StudentHistoryView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:StudentSettingsViewModel}"><views:StudentSettingsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ErrorPageViewModel}"><views:ErrorPageView /></DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="268" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Margin="20,22,20,18">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="42" Height="42" CornerRadius="12" Background="{DynamicResource PrimaryBrush}">
                            <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" FontSize="21" Foreground="White" />
                        </Border>
                        <StackPanel Margin="12,1,0,0">
                            <TextBlock Text="ExamTransfer" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="LOCAL-FIRST EXAM SUITE" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource SidebarMutedBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Row="1" Margin="14,0,14,14" Padding="12" CornerRadius="11" Background="{DynamicResource SidebarHoverBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding AccountDisplay}" Foreground="White" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding AccountRole}" Foreground="{DynamicResource SidebarMutedBrush}" FontSize="10" />
                            <TextBlock Text="{Binding SessionStatusText}" Foreground="{DynamicResource SidebarMutedBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding LogoutCommand}" Style="{StaticResource GhostButton}" ToolTip="Đăng xuất" MinWidth="34" MinHeight="34" Padding="6">
                            <TextBlock Text="&#xE8BB;" Style="{StaticResource IconText}" FontSize="15" Foreground="{DynamicResource SidebarTextBrush}" />
                        </Button>
                    </Grid>
                </Border>

                <ListBox Grid.Row="2"
                         Style="{StaticResource SidebarListBox}"
                         ItemContainerStyle="{StaticResource SidebarItem}"
                         ItemsSource="{Binding Source={StaticResource GroupedNavigation}}"
                         SelectedItem="{Binding Selected, Mode=TwoWay}">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Margin="22,18,12,7"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SidebarMutedBrush}" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:NavigationItem}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Glyph}" Style="{StaticResource IconText}" FontSize="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" />
                                <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="10,0,8,0" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}}" />
                                <Border Grid.Column="2" CornerRadius="999" Padding="7,2" Background="#33FFFFFF">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Badge}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Badge}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Badge}" FontSize="9" FontWeight="Bold" Foreground="White" TextWrapping="NoWrap" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="3" Margin="14,12,14,18">
                    <Border Padding="12" CornerRadius="10" Background="{DynamicResource SidebarHoverBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource PrimaryBrush}">
                                <TextBlock Text="ET" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0">
                                <TextBlock Text="{Binding ModeTitle}" Foreground="White" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" />
                                <TextBlock Text="{Binding EnvironmentLabel}" Foreground="{DynamicResource SidebarMutedBrush}" FontSize="10" />
                            </StackPanel>
                            <Button Grid.Column="2" Command="{Binding ToggleThemeCommand}" Style="{StaticResource GhostButton}" ToolTip="{Binding ThemeLabel}" MinWidth="34" MinHeight="34" Padding="6">
                                <TextBlock Text="&#xE706;" Style="{StaticResource IconText}" FontSize="15" Foreground="{DynamicResource SidebarTextBrush}" />
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="76" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PageGlyph}" Style="{StaticResource IconText}" FontSize="18" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding PageTitle}" FontSize="20" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock Text="{Binding PageDescription}" Style="{StaticResource CaptionText}" Margin="28,2,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Style="{StaticResource StatusPill}"
                                Background="{Binding ConnectionTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="{Binding ConnectionTone, Converter={StaticResource ToneBrushConverter}}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Connection}" Margin="7,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{Binding ConnectionTone, Converter={StaticResource ToneBrushConverter}}" />
                            </StackPanel>
                        </Border>
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource GhostButton}" Margin="8,0,0,0" ToolTip="Kiểm tra lại kết nối">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconText}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
