<UserControl x:Class="ExamTransfer.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:ExamTransfer.Desktop.Behaviors"
             beh:EntranceAnimation.IsEnabled="True">
    <Grid Margin="32">
        <Border Style="{StaticResource Card}" MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <Border Width="56" Height="56" CornerRadius="16" Background="{DynamicResource PrimarySoftBrush}" HorizontalAlignment="Left">
                    <TextBlock Text="&#xE8D7;" Style="{StaticResource IconText}" FontSize="25" Foreground="{DynamicResource PrimaryBrush}" />
                </Border>
                <TextBlock Text="Đăng nhập ExamTransfer" Style="{StaticResource DisplayTitleText}" Margin="0,18,0,6" />
                <TextBlock Text="Sử dụng tài khoản đã được quản trị viên cấp." Style="{StaticResource BodyText}" />

                <StackPanel Margin="0,22,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConfirmingStudent}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Tài khoản hoặc email" FontWeight="SemiBold" FontSize="12" />
                    <TextBox Text="{Binding Account, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,14" />
                    <TextBlock Text="Mật khẩu" FontWeight="SemiBold" FontSize="12" />
                    <PasswordBox x:Name="PasswordInput" PasswordChanged="OnPasswordChanged" Margin="0,6,0,0" />
                    <Button Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0" MinHeight="42" Content="Đăng nhập" />
                </StackPanel>

                <StackPanel Margin="0,22,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConfirmingStudent}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Xác nhận sinh viên" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Mã sinh viên" FontWeight="SemiBold" FontSize="12" Margin="0,14,0,0" />
                    <TextBox Text="{Binding StudentCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                    <TextBlock Text="Họ tên" FontWeight="SemiBold" FontSize="12" />
                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button Command="{Binding BackToLoginCommand}" Style="{StaticResource SecondaryButton}" MinHeight="42" Content="Quay lại" />
                        <Button Grid.Column="2" Command="{Binding ConfirmStudentCommand}" Style="{StaticResource PrimaryButton}" MinHeight="42" Content="Xác nhận" />
                    </Grid>
                </StackPanel>

                <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Left" Margin="0,18,0,0"
                        Background="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}, ConverterParameter=soft}">
                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusTone, Converter={StaticResource ToneBrushConverter}}" TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="{Binding DeviceId, StringFormat=Device ID: {0}}" Style="{StaticResource CaptionText}" Margin="0,14,0,0" FontFamily="Consolas" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
